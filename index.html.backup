    overview:`Pipeline starts at hardware — a color sensor reads reflected RGB from a physical paint sample. That raw signal is normalized and fed to a Create ML regression model trained on known pigment mixtures. The model predicts mixing ratios for each pigment channel in real time.`,
    snippets:[{file:'pipeline/inference.py',code:`<span class="ck">class</span> <span class="cf">PaintInferencePipeline</span>:
    <span class="cc2"># TODO: Replace with actual model path</span>
    MODEL_PATH = <span class="cs">"models/paint_color_matcher.mlmodel"</span>

    <span class="ck">def</span> <span class="cf">predict</span>(self, raw_sensor: dict) -> dict:
        r = raw_sensor[<span class="cs">"red"</span>]   / <span class="cn">65535.0</span>
        g = raw_sensor[<span class="cs">"green"</span>] / <span class="cn">65535.0</span>
        b = raw_sensor[<span class="cs">"blue"</span>]  / <span class="cn">65535.0</span>
        result = self.model.<span class="cf">predict</span>({<span class="cs">"r_norm"</span>: r, <span class="cs">"g_norm"</span>: g, <span class="cs">"b_norm"</span>: b})
        <span class="ck">return</span> {<span class="cs">"cyan"</span>: result[<span class="cs">"cyan_pct"</span>],   <span class="cc2"># TODO: verify keys</span>
                <span class="cs">"magenta"</span>: result[<span class="cs">"magenta_pct"</span>],
