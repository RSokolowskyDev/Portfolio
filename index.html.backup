};

/* ════════════════════════════════════════════════
   FLOATING BUBBLE GRID (formerly "watch face")
   ════════════════════════════════════════════════ */
function buildWatchFace(){
  const wf=document.getElementById('watchface');
  const wrap=document.getElementById('wf-wrap');
  if(!wf||!wrap)return;

  /* Build bubbles */
  BUBBLE_POS.forEach(bp=>{
    const p=PROJECTS.find(x=>x.id===bp.id);
    if(!p)return;
    const sz=p.sz||90;
    const el=document.createElement('div');
    el.className='wbubble'+(p.featured?' feat':'');
    el.dataset.id=p.id;
    el.style.cssText=`width:${sz}px;height:${sz}px;left:${bp.cx-sz/2}px;top:${bp.cy-sz/2}px;`;
    el.innerHTML=`<div class="wbubble-inner" style="background:${p.grad};">
      <div class="wb-icon">${p.icon}</div>
      <div class="wb-name">${p.name}</div>
    </div>`;

    el.addEventListener('mouseenter',()=>{
      /* Activate this bubble, dim all others */
      wf.classList.add('is-hovering');
      wf.querySelectorAll('.wbubble').forEach(b=>b.classList.remove('active'));
      el.classList.add('active');
      showPIP(p.id);
    });

    el.addEventListener('click',()=>openModal(p.id));
    wf.appendChild(el);
  });

  /* When mouse leaves the entire grid area, restore default faded state */
  wrap.addEventListener('mouseleave',()=>{
    wf.classList.remove('is-hovering');
    wf.querySelectorAll('.wbubble').forEach(b=>b.classList.remove('active'));
    wf.style.transform='rotateX(0) rotateY(0)';
    hidePIP();
  });

  /* 3D parallax tilt — tracks across the whole wrap */
  wrap.addEventListener('mousemove',e=>{
    const r=wf.getBoundingClientRect();
    const cx=r.left+r.width/2, cy=r.top+r.height/2;
    const dx=(e.clientX-cx)/(r.width/2), dy=(e.clientY-cy)/(r.height/2);
    /* Clamp so it doesn't flip on edges */
    const rx=Math.max(-1,Math.min(1,dy));
    const ry=Math.max(-1,Math.min(1,dx));
    wf.style.transform=`rotateX(${-rx*13}deg) rotateY(${ry*13}deg)`;
  });
}

/* Info panel */
function showPIP(id){
  const p=PROJECTS.find(x=>x.id===id);if(!p)return;
  document.getElementById('pip-default').style.display='none';
  const ap=document.getElementById('pip-active');
  ap.classList.add('show');
  document.getElementById('pip-num').textContent=`${p.num} / ${p.name.toUpperCase()}`;
  const lv=document.getElementById('pip-live');lv.style.display=p.live?'inline-flex':'none';
  document.getElementById('pip-icon').textContent=p.icon;
  document.getElementById('pip-name').textContent=p.name;
  document.getElementById('pip-sub').textContent=p.sub;
  document.getElementById('pip-desc').textContent=p.desc;
  document.getElementById('pip-tags').innerHTML=tagsH(p.tags);
  const acts=document.getElementById('pip-acts');
  acts.innerHTML=`<button class="pip-open" onclick="openModal('${p.id}')">Open Details →</button>`
    +p.links.filter(l=>l.p||l.g).slice(0,2).map(lk=>{
      const ic=lk.g?GH:EXT;
      return `<a href="${lk.u}" target="_blank" rel="noopener" class="pip-link" onclick="event.stopPropagation()">${ic}${lk.l}</a>`;
    }).join('');
}
function hidePIP(){
  document.getElementById('pip-default').style.display='';
  document.getElementById('pip-active').classList.remove('show');
}

/* ════════════════════════════════════════════════
   LIST VIEW TOGGLE
   ════════════════════════════════════════════════ */
let listShown=false;
function toggleListView(){
  listShown=!listShown;
  const lv=document.getElementById('list-view');
  const btn=document.getElementById('lt-list');
  lv.classList.toggle('show',listShown);
  btn.classList.toggle('act',listShown);
  btn.querySelector('svg+*')||(btn.innerHTML=btn.innerHTML);
  btn.childNodes[btn.childNodes.length-1].textContent=listShown?' Hide list':' View detailed list';
  if(listShown && !lv.children.length) renderCards();
}
function renderCards(){
  const g=document.getElementById('list-view');
  PROJECTS.forEach((p,i)=>{
    const delay=i===0?'':` d${Math.min((i%4)+1,4)}`;
    if(p.featured){
      g.innerHTML+=`<div class="pc pc-feat-card fi${delay}" onclick="openModal('${p.id}')">
        <div class="pc-l">
          <span class="live-badge">Live Demo</span>
          <div class="pnum">${p.num} / ${p.name.toUpperCase()}</div>
          <div class="picon">${p.icon}</div>
          <h3 class="pname">${p.name}</h3><div class="psub">${p.sub}</div>
          <p class="pdesc">${p.desc}</p>
          <ul class="pbullets">${p.bullets.map(b=>`<li>${b}</li>`).join('')}</ul>
          <div class="ptags">${tagsH(p.tags)}</div>
          <div class="plinks">${linksH(p.links)}</div>
        </div>
        <div class="pc-r">
          <div class="arch-title">// Agent Pipeline — ${p.arch.length} Steps</div>
          ${p.arch.map(a=>`<div class="arch-row"><div class="anum">${a.n}</div><div class="astep">${a.a}</div><div class="atech">${a.t}</div></div>`).join('')}
        </div>
        <div class="pc-zoom-hint">${ZOOM} Click to deep dive</div>
      </div>`;
    }else{
      g.innerHTML+=`<div class="pc fi${delay}" onclick="openModal('${p.id}')">
        <div class="pnum">${p.num} / ${p.name.toUpperCase()}</div>
        <div class="picon">${p.icon}</div>
        <h3 class="pname">${p.name}</h3><div class="psub">${p.sub}</div>
        <p class="pdesc">${p.desc}</p>
        <ul class="pbullets">${p.bullets.map(b=>`<li>${b}</li>`).join('')}</ul>
        <div class="ptags">${tagsH(p.tags)}</div>
        <div class="plinks">${linksH(p.links)}</div>
        <div class="pc-zoom-hint">${ZOOM} Click to deep dive</div>
      </div>`;
    }
  });
  observeAnimated();
}

/* ════════════════════════════════════════════════
   MODAL
   ════════════════════════════════════════════════ */
let _mTerm=null;
function openModal(id,startTab){
  const p=PROJECTS.find(x=>x.id===id);if(!p)return;
  document.getElementById('m-ico').textContent=p.icon;
  document.getElementById('m-nm').textContent=p.name;
  document.getElementById('m-sb').textContent=p.sub;
  const tabsDef=[
    {k:'overview',l:'Overview'},
    {k:'arch',l:'Architecture'},
    {k:'code',l:'Code'},
    ...(p.demo?[{k:'tryit',l:'🎮 Try It'}]:[]),
  ];
  const tabsEl=document.getElementById('m-tabs');
  const pnlsEl=document.getElementById('m-panels');
  tabsEl.innerHTML='';pnlsEl.innerHTML='';
  tabsDef.forEach(td=>{
    const t=document.createElement('div');
    t.className='m-tab';t.dataset.k=td.k;t.textContent=td.l;
    t.addEventListener('click',()=>switchTab(td.k));
    tabsEl.appendChild(t);
  });
  // Overview
  const ov=document.createElement('div');ov.className='m-panel';ov.dataset.p='overview';
  ov.innerHTML=`<div class="m-2col">
    <div class="m-left">
      ${p.live?'<span class="live-badge">Live Demo</span>':''}
      <div><div class="mlbl">Overview</div><p class="m-txt">${p.overview}</p></div>
      <div><div class="mlbl">Stack</div><div class="ptags">${tagsH(p.tags)}</div></div>
      <div><div class="mlbl">Links</div><div class="plinks">${linksH(p.links)}</div></div>
      <div><div class="mlbl">Metrics</div><div class="metrics-g">${p.metrics.map(m=>`<div class="mc"><div class="mc-v">${m.v}</div><div class="mc-l">${m.l}</div></div>`).join('')}</div></div>
    </div>
    <div class="m-right"><div class="m-sect"><div class="mlbl">Key Points</div><ul class="m-buls">${p.bullets.map(b=>`<li>${b}</li>`).join('')}</ul></div></div>
  </div>`;
  pnlsEl.appendChild(ov);
  // Architecture
  const ar=document.createElement('div');ar.className='m-panel';ar.dataset.p='arch';
  ar.innerHTML=`<div class="m-right" style="width:100%;overflow-y:auto;"><div class="m-sect"><div class="mlbl">Architecture Breakdown</div>
    ${p.arch.map(a=>`<div class="m-arch-row"><div class="m-an">${a.n}</div><div class="m-aw"><div class="m-as">${a.a}</div><div class="m-ad">${a.d}</div><div class="m-at">${a.t}</div></div></div>`).join('')}
  </div></div>`;
  pnlsEl.appendChild(ar);
  // Code
  const cd=document.createElement('div');cd.className='m-panel';cd.dataset.p='code';
  cd.innerHTML=`<div style="overflow-y:auto;height:100%;">${p.snippets.map(s=>`<div class="code-fb">${s.file}</div><div class="code-blk"><pre>${s.code}</pre></div>`).join('')}</div>`;
  pnlsEl.appendChild(cd);
  // Try It
  if(p.demo){
    const ti=document.createElement('div');ti.className='m-panel';ti.dataset.p='tryit';
    const tid=`mt-${p.id}`;
    ti.innerHTML=`<div class="m-tryit">
      <div class="tryit-hint">${BACKEND_LIVE?'<span style="color:var(--green)">Live backend connected</span>':'<span style="color:var(--amber)">Simulated · TODO_BACKEND: set API_BASE and flip BACKEND_LIVE=true</span>'}<br/>Hint: ${p.demo.hint}</div>
      <div class="term-wrap" style="flex:1;min-height:300px;">
        <div class="term-bar"><div class="td r"></div><div class="td y"></div><div class="td g"></div>
          <span class="term-title">${p.name.toLowerCase().replace(/ /g,'-')}</span>
          <span class="tbadge ${BACKEND_LIVE?'tb-live':'tb-sim'}" style="margin-left:auto;">${BACKEND_LIVE?'Live':'Simulated'}</span>
        </div>
        <div class="term-output" id="${tid}-out"></div>
        <div class="term-input-row"><span class="tp">$&nbsp;</span><input class="term-input" id="${tid}-inp" type="text" autocomplete="off" spellcheck="false" placeholder="type help"/></div>
      </div>
    </div>`;
    pnlsEl.appendChild(ti);
  }
  function switchTab(k){
    tabsEl.querySelectorAll('.m-tab').forEach(t=>t.classList.toggle('act',t.dataset.k===k));
    pnlsEl.querySelectorAll('.m-panel').forEach(t=>t.classList.toggle('act',t.dataset.p===k));
    if(k==='tryit'&&p.demo){
      const tid=`mt-${p.id}`;
      const outEl=document.getElementById(tid+'-out');
      if(outEl&&!outEl._ti){outEl._ti=true;requestAnimationFrame(()=>{
        _mTerm=new Terminal(tid+'-out',tid+'-inp',p.demo.cmds,{greeting:[{t:'dim',v:`  # ${p.name} — type help`}]});
      });}
      setTimeout(()=>{document.getElementById(tid+'-inp')?.focus();},80);
    }
  }
  switchTab(startTab||'overview');
  document.getElementById('m-overlay').classList.add('open');
  document.body.style.overflow='hidden';
}
function closeModal(){
  document.getElementById('m-overlay').classList.remove('open');
  document.body.style.overflow='';
  if(_droneIv){clearInterval(_droneIv);_droneIv=null;}
}
function handleOC(e){if(e.target.id==='m-overlay')closeModal();}
document.addEventListener('keydown',e=>{if(e.key==='Escape')closeModal();});

/* ════════════════════════════════════════════════
   SKILLS RENDER
   ════════════════════════════════════════════════ */
function renderSkills(){
  const cont=document.getElementById('skills-container');if(!cont)return;
  SKILLS.forEach((cat,ci)=>{
    const div=document.createElement('div');div.className='fi d'+Math.min(ci+1,4);
    div.innerHTML=`<div class="skill-cat-label">${cat.cat}</div>
      <div class="skill-icons-row">${cat.items.map((sk,si)=>`
        <div class="skill-icon-badge" style="animation-delay:${ci*.1+si*.04}s;">
          <div class="sib-circle" style="background:${sk.bg};">${sk.icon}</div>
          <div class="sib-name">${sk.name}</div>
        </div>`).join('')}
      </div>`;
    cont.appendChild(div);
  });
}

/* ════════════════════════════════════════════════
   SCROLL LINE
   ════════════════════════════════════════════════ */
function initScrollLine(){
  const fill=document.getElementById('slf');
  const dots=document.querySelectorAll('.sld');
  const sections=['home','projects','about','skills','contact'];
  dots.forEach(d=>{
    d.addEventListener('click',()=>{
      const sec=document.getElementById(d.dataset.s);
      if(sec)sec.scrollIntoView({behavior:'smooth'});
    });
  });
  window.addEventListener('scroll',()=>{
    const prog=window.scrollY/(document.documentElement.scrollHeight-window.innerHeight);
    if(fill)fill.style.height=(prog*100)+'%';
    let cur='home';
    sections.forEach(id=>{const el=document.getElementById(id);if(el&&window.scrollY>=el.offsetTop-80)cur=id;});
    dots.forEach(d=>d.classList.toggle('act',d.dataset.s===cur));
    // active nav links
    document.querySelectorAll('.navul a').forEach(a=>{a.classList.toggle('act',a.getAttribute('href')==='#'+cur);});
  },{passive:true});
}

/* ════════════════════════════════════════════════
   INTERSECTION OBSERVER
   ════════════════════════════════════════════════ */
const io=new IntersectionObserver(es=>{es.forEach(e=>{if(e.isIntersecting)e.target.classList.add('v');});},{threshold:0.06});
function observeAnimated(){document.querySelectorAll('.fi:not([data-ob])').forEach(el=>{el.setAttribute('data-ob','1');io.observe(el);});}

/* ════════════════════════════════════════════════
   MOUSE GLOW ON CARDS
   ════════════════════════════════════════════════ */
document.addEventListener('mousemove',e=>{
  document.querySelectorAll('.pc').forEach(c=>{
    const r=c.getBoundingClientRect();
    c.style.setProperty('--mx',((e.clientX-r.left)/r.width*100)+'%');
    c.style.setProperty('--my',((e.clientY-r.top)/r.height*100)+'%');
  });
});

/* ════════════════════════════════════════════════
   INIT
   ════════════════════════════════════════════════ */
buildWatchFace();
renderSkills();
observeAnimated();
initScrollLine();

new Terminal('hero-out','hero-inp',heroCmds,{
  greeting:[{t:'dim',v:'  # Portfolio terminal — type help'},{t:'blank'}]
});
</script>
</body>
</html>
