/* ════════════════════════════════════════════════
   UTILS
   ════════════════════════════════════════════════ */
const sleep = ms => new Promise(r => setTimeout(r,ms));
const rand  = (a,b) => Math.floor(Math.random()*(b-a+1))+a;
const rf    = (a,b) => (Math.random()*(b-a)+a).toFixed(1);
const escH  = s => String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
function parseArgs(arr){
  const o={};
  for(let i=0;i<arr.length;i++){
    if(arr[i].startsWith('--')){o[arr[i].slice(2)]=arr[i+1]||true;i++;}
    else{o._rest=(o._rest||[]).concat(arr[i]);}
  }
  return o;
}
function bar(pct,len=16,color='var(--cyan)'){
  const f=Math.round(pct/100*len),e=len-f;
  return `<span style="display:inline-block;width:${f*6}px;height:9px;border-radius:2px;background:${color};vertical-align:middle;"></span>`
        +`<span style="display:inline-block;width:${e*6}px;height:9px;border-radius:2px;background:rgba(255,255,255,.07);vertical-align:middle;"></span>`;
}
function tagsH(tags){return tags.map(([l,c])=>`<span class="tag ${c}">${l}</span>`).join('');}
function linksH(links){return links.map(lk=>{
  const icon=lk.g?GH:lk.p?EXT:DASH;
  const cls=lk.p?'pl pl-p':'pl';
  return `<a href="${lk.u}" target="_blank" rel="noopener" class="${cls}" onclick="event.stopPropagation()">${icon}${lk.l}</a>`;
}).join('');}

/* ════════════════════════════════════════════════
   TERMINAL CLASS
   ════════════════════════════════════════════════ */
class Terminal {
  constructor(outId, inpId, cmds, {greeting=[]}={}){
    this.out=document.getElementById(outId);
    this.inp=document.getElementById(inpId);
    this.cmds=cmds; this.hist=[]; this.hidx=-1; this.locked=false;
    if(!this.out||!this.inp)return;
    greeting.forEach(g=>this.addLine(g.t,g.v));
    this.inp.addEventListener('keydown',e=>this.onKey(e));
    this.out.parentElement?.addEventListener('click',()=>this.inp.focus());
  }
  addLine(type,text){
    if(!this.out)return;
    const el=document.createElement('div');
    el.className=`tl ${type}`;
    if(type==='cmd'){el.innerHTML=`<span class="tp">$&nbsp;</span><span class="tv">${escH(text)}</span>`;}
    else if(type==='blank'){el.style.height='8px';}
    else{el.innerHTML=`<span class="tv">${text}</span>`;}
    this.out.appendChild(el);
    this.out.scrollTop=this.out.scrollHeight;
  }
  lines(arr){arr.forEach(l=>this.addLine(l.t,l.v));}
  clear(){if(this.out)this.out.innerHTML='';}
  async stream(linesArr,delay=32){for(const l of linesArr){await sleep(delay);this.addLine(l.t,l.v);}}
  async onKey(e){
    if(this.locked){e.preventDefault();return;}
    if(e.key==='Enter'){
      const raw=this.inp.value.trim(); this.inp.value='';
      if(!raw)return;
      this.hist.unshift(raw); this.hidx=-1;
      this.addLine('cmd',raw);
      const[cmd,...args]=raw.toLowerCase().split(/\s+/);
      if(cmd==='clear'){this.clear();return;}
      if(this.cmds[cmd]){this.locked=true;try{await this.cmds[cmd](args,this);}catch(err){this.addLine('err','  Error: '+err.message);}this.locked=false;}
      else{this.addLine('err',`  Unknown: ${escH(cmd)}. Type help.`);}
    }else if(e.key==='ArrowUp'){e.preventDefault();if(this.hidx<this.hist.length-1)this.inp.value=this.hist[++this.hidx];}
    else if(e.key==='ArrowDown'){e.preventDefault();this.hidx>0?this.inp.value=this.hist[--this.hidx]:(this.inp.value='',this.hidx=-1);}
  }
}

/* ════════════════════════════════════════════════
   DEMO: SENTINEL
   ════════════════════════════════════════════════ */
const _sStats={total:0,saved:0,validated:0};
async function demoSentinel(prompt,term){
  if(!prompt.trim()){term.addLine('err','  Provide a prompt. E.g.: analyze What is Python?');return;}
  /* TODO_BACKEND: const data = await fetch(`${API_BASE}/api/sentinel/analyze`,
     {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({prompt})}).then(r=>r.json()); */
  const tc=Math.max(4,Math.round(prompt.split(' ').length*1.33));
  const budget=tc<2048;
  const model=budget?'claude-haiku-3.5':'claude-3-opus';
  const conf=(Math.random()*.13+0.85).toFixed(2);
  const saved=rand(80,400);
  const cost=(tc*(budget?.000003:.000015)).toFixed(6);
  _sStats.total++;_sStats.saved+=saved;_sStats.validated++;
  await term.stream([{t:'blank'},{t:'hl',v:'  ─── Sentinel Analysis ─────────────────────────'},{t:'out',v:`  Prompt: "${escH(prompt.slice(0,55))}${prompt.length>55?'…':''}"`},{t:'out',v:`  Token estimate: ${tc} tokens`}],38);
  await sleep(180);
  await term.stream([{t:'blank'},{t:'key',v:'  Routing Decision'},{t:'out',v:`  Budget threshold : 2048 tokens`},{t:'out',v:`  Input count      : ${tc} tokens`},{t:budget?'ok':'key',v:`  → Model selected : ${model} ${budget?'(budget ✓)':'(primary)'}`}],34);
  await sleep(280);
  await term.stream([{t:'blank'},{t:'key',v:'  Dual Validation'},{t:'out',v:'  Generating candidate...'},{t:'out',v:'  Running validator pass...'},{t:'out',v:`  Confidence score  : ${conf}`},{t:parseFloat(conf)>=.82?'ok':'err',v:`  Threshold (0.82)  : ${parseFloat(conf)>=.82?'PASS ✓':'RETRY ↺'}`}],38);
  await sleep(180);
  await term.stream([{t:'blank'},{t:'ok',v:`  Cost estimate : $${cost}`},{t:'ok',v:`  Est. savings  : ~${saved} tokens vs full model`},{t:'blank'}],28);
}
function demoSentinelStats(term){
  term.lines([{t:'blank'},{t:'hl',v:'  ─── Session Stats ──────────────'},{t:'out',v:`  Requests   : ${_sStats.total}`},{t:'out',v:`  Tokens saved: ~${_sStats.saved}`},{t:'blank'}]);
}

/* ════════════════════════════════════════════════
   DEMO: MARK MILLER
   ════════════════════════════════════════════════ */
const _leads=[];
async function demoLeadScore(args,term){
  const a=parseArgs(args);
  const name=a.name||'Unknown',vehicle=a.vehicle||'Subaru',budget=parseInt(a.budget||'30000'),contact=a.contact||'email';
  /* TODO_BACKEND: const data = await fetch(`${API_BASE}/api/leads/score`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({name,vehicle_interest:vehicle,budget,contact_method:contact})}).then(r=>r.json()); */
  const score=budget>40000?rand(7,10):budget>25000?rand(5,8):rand(2,5);
  const tier=score>=8?'HOT 🔥':score>=5?'WARM ☀️':'COLD ❄️';
  const tc2=score>=8?'ok':score>=5?'key':'out';
  const spec=['Sarah (Subaru Expert)','Mike (Fleet Sales)','Jordan (Finance Specialist)'][rand(0,2)];
  const tps=[`${vehicle}'s all-weather capability`,`Budget of $${budget.toLocaleString()} aligns with ${score>6?'Premium':'base'} trim`,`Current ${(2.9+Math.random()).toFixed(1)}% APR financing offer`];
  const lid='LD-'+Math.random().toString(36).slice(2,7).toUpperCase();
  _leads.push({lid,name,vehicle,budget,score,tier:tier.split(' ')[0]});
  await term.stream([{t:'blank'},{t:'hl',v:'  ─── Lead Analyst Agent ──────────────────────'},{t:'out',v:`  Processing: ${escH(name)} | ${escH(vehicle)} | $${budget.toLocaleString()}`}],28);
  await sleep(380);
  await term.stream([{t:'out',v:'  Running CrewAI pipeline...'},{t:'out',v:'  [Lead Analyst]     → scoring inquiry...'},{t:'out',v:'  [Lead Analyst]     → assigning specialist...'}],75);
  await sleep(480);
  await term.stream([{t:'blank'},{t:'key',v:`  Lead ID : ${lid}`},{t:tc2,v:`  Score   : ${score}/10   Tier: ${tier}`},{t:'out',v:`  Specialist: ${spec}`},{t:'blank'},{t:'key',v:'  Talking Points:'},{...tps.map(tp=>({t:'out',v:`    › ${tp}`}))}.map&&tps.map(tp=>({t:'out',v:`    › ${tp}`})),...[]}.slice(-1);
  // simpler approach:
  for(const tp of tps)term.addLine('out',`    › ${tp}`);
  await term.stream([{t:'blank'},{t:'out',v:'  [Comms Specialist]  → drafting email...'}],40);
  await sleep(550);
  await term.stream([{t:'ok',v:'  Email drafted ✓'},{t:'dim',v:`  Preview: "Hi ${name.split(' ')[0]}, I noticed your interest in the ${vehicle}..."`},{t:'blank'},{t:'ok',v:`  Lead queued. Type 'leads' to view.`},{t:'blank'}],32);
}
function demoListLeads(term){
  if(!_leads.length){term.addLine('out','  No leads yet. Try: score --name "Alex" --vehicle "Outback" --budget 38000');return;}
  term.lines([{t:'blank'},{t:'hl',v:'  ─── Recent Leads ──────────────────────────'}]);
  _leads.forEach(l=>{const c=l.tier==='HOT'?'ok':l.tier==='WARM'?'key':'out';term.addLine(c,`  ${l.lid}  ${l.name.padEnd(14)} ${l.vehicle.padEnd(12)} $${l.budget.toLocaleString().padEnd(7)} [${l.tier}] ${l.score}/10`);});
  term.addLine('blank','');
}

/* ════════════════════════════════════════════════
   DEMO: DRONE
   ════════════════════════════════════════════════ */
let _droneIv=null,_droneWp=0;
function _dd(){
  _droneWp=Math.min(_droneWp+(Math.random()>.95?1:0),8);
  return{lat:(40.7128+(Math.random()-.5)*.002).toFixed(6),lon:(-74.006+(Math.random()-.5)*.002).toFixed(6),
    alt:rf(12,18),spd:rf(3.2,5.8),hdg:rand(220,275),batt:Math.max(20,rand(65,95)),
    rssi:rand(-72,-52),roll:rf(-2.5,2.5),pitch:rf(-1.5,1.5),wp:_droneWp,mode:_droneWp===8?'RTL':'AUTO'};
}
function startDroneFeed(term){
  /* TODO_BACKEND: Replace interval body with real MAVLink telemetry fetch */
  if(_droneIv){term.addLine('out','  Feed already running. Type stop to halt.');return;}
  _droneWp=0;
  term.lines([{t:'blank'},{t:'ok',v:'  Connecting to telemetry... ✓'},{t:'ok',v:'  Receiving data (simulated — TODO_BACKEND: wire to ArduPilot MAVLink)'},{t:'blank'}]);
  _droneIv=setInterval(()=>{
    const d=_dd();
    term.lines([{t:'hl',v:`  [TELEM] MODE:${d.mode}  WP:${d.wp}/8  BATT:${d.batt}%`},{t:'out',v:`  ALT:${d.alt}m  SPD:${d.spd}m/s  HDG:${d.hdg}°  RSSI:${d.rssi}dBm`},{t:'out',v:`  GPS:${d.lat}°N  ROLL:${d.roll}°  PITCH:${d.pitch}°`},{t:'dim',v:`  [Lua] wp=${d.wp} ${d.wp===3?'→ HOLD 10s':'→ continue'}`},{t:'blank'}]);
    if(d.mode==='RTL'){clearInterval(_droneIv);_droneIv=null;term.addLine('ok','  Mission complete. RTL.');}
  },2000);
}
function stopDroneFeed(term){if(!_droneIv){term.addLine('out','  No active feed.');return;}clearInterval(_droneIv);_droneIv=null;term.lines([{t:'blank'},{t:'ok',v:'  Feed stopped.'},{t:'blank'}]);}
function droneSingleStatus(term){const d=_dd();term.lines([{t:'blank'},{t:'hl',v:`  [STATUS] MODE:${d.mode}  WP:${d.wp}/8  BATT:${d.batt}%`},{t:'out',v:`  ALT:${d.alt}m  SPD:${d.spd}m/s  HDG:${d.hdg}°`},{t:'blank'}]);}

/* ════════════════════════════════════════════════
   DEMO: PAINT MATCHER
   ════════════════════════════════════════════════ */
async function demoPaint(args,term){
  const a=parseArgs(args);
  let r,g,b;
  if(a.hex){const h=a.hex.replace('#','');r=parseInt(h.slice(0,2),16);g=parseInt(h.slice(2,4),16);b=parseInt(h.slice(4,6),16);}
  else{r=parseInt(a.r||'128');g=parseInt(a.g||'128');b=parseInt(a.b||'128');if(isNaN(r)||isNaN(g)||isNaN(b)){term.addLine('err','  Use --r 224 --g 107 --b 45 or --hex #E06B2D');return;}}
  r=Math.min(255,Math.max(0,r));g=Math.min(255,Math.max(0,g));b=Math.min(255,Math.max(0,b));
  /* TODO_BACKEND: const result = await fetch(`${API_BASE}/api/paint/match`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({r,g,b})}).then(x=>x.json()); */
  const rn=r/255,gn=g/255,bn=b/255,k=1-Math.max(rn,gn,bn),kd=k===1?1:1-k;
  const cy=Math.round(((1-rn-k)/kd||0)*100),ma=Math.round(((1-gn-k)/kd||0)*100);
  const ye=Math.round(((1-bn-k)/kd||0)*100),bl=Math.round(k*100);
  const conf=(0.86+Math.random()*.1).toFixed(2);
  const hex6='#'+[r,g,b].map(x=>x.toString(16).padStart(2,'0')).join('');
  const names=['Burnt Sienna','Cerulean Blue','Forest Green','Crimson Red','Ochre Yellow','Cobalt Violet','Raw Umber','Titanium White'];
  const cn=names[Math.floor(Math.random()*names.length)];
  await term.stream([{t:'blank'},{t:'hl',v:'  ─── Paint Color Matcher ────────────────────'},{t:'out',v:`  Input: rgb(${r}, ${g}, ${b})`},{t:'out',v:`  Preview: <span style="display:inline-block;width:14px;height:14px;background:${hex6};border-radius:3px;vertical-align:middle;border:1px solid rgba(255,255,255,.2);"></span> ${hex6}`},{t:'blank'},{t:'out',v:'  Normalizing & running Create ML inference...'}],35);
  await sleep(450);
  await term.stream([{t:'blank'},{t:'key',v:'  Predicted Mixing Ratios:'},{t:'out',v:`  Cyan    ${String(cy+'%').padEnd(5)} ${bar(cy,18,'var(--cyan)')}`},{t:'out',v:`  Magenta ${String(ma+'%').padEnd(5)} ${bar(ma,18,'var(--pink)')}`},{t:'out',v:`  Yellow  ${String(ye+'%').padEnd(5)} ${bar(ye,18,'var(--amber)')}`},{t:'out',v:`  Black   ${String(bl+'%').padEnd(5)} ${bar(bl,18,'#8899b8')}`},{t:'blank'},{t:'ok',v:`  Confidence: ${conf}   Closest match: "${cn}"`},{t:'blank'}],38);
}
async function demoPaintRandom(term){const r=rand(0,255),g=rand(0,255),b=rand(0,255);term.addLine('dim',`  Simulating sensor capture: rgb(${r},${g},${b})`);await sleep(250);await demoPaint([`--r`,`${r}`,'--g',`${g}`,'--b',`${b}`],term);}

/* ════════════════════════════════════════════════
   HERO TERMINAL
   ════════════════════════════════════════════════ */
