<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Ryan Sokolowsky — AI Solutions Engineer</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=JetBrains+Mono:wght@300;400;500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
<style>
/* ═══════════════════ TOKENS ═══════════════════ */
:root{
  --bg:#05070c; --surf:rgba(255,255,255,.032); --surf2:rgba(255,255,255,.055);
  --bdr:rgba(255,255,255,.07); --bdr2:rgba(255,255,255,.13);
  --cyan:#22d3ee; --indigo:#818cf8; --purple:#a855f7;
  --text:#e2e8f4; --muted:#4a5c75; --muted2:#7289a8;
  --green:#34d399; --amber:#fbbf24; --pink:#f472b6; --red:#f87171;
  --r:14px; --mono:'JetBrains Mono',monospace;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;line-height:1.6;overflow-x:hidden;}

/* ═══════════════════ AURORA ═══════════════════ */
.ab{position:fixed;inset:0;z-index:0;overflow:hidden;pointer-events:none;}
.bl{position:absolute;border-radius:50%;filter:blur(110px);opacity:.1;}
.b1{width:700px;height:700px;background:var(--indigo);top:-220px;left:-180px;animation:aura 28s ease-in-out infinite;}
.b2{width:580px;height:580px;background:var(--cyan);bottom:-180px;right:-160px;animation:aura 34s ease-in-out infinite reverse;}
.b3{width:460px;height:460px;background:var(--purple);top:42%;left:43%;animation:aura 22s ease-in-out infinite -11s;}
@keyframes aura{0%,100%{transform:translate(0,0)scale(1);}25%{transform:translate(50px,-65px)scale(1.13);}50%{transform:translate(-35px,55px)scale(.88);}75%{transform:translate(45px,35px)scale(1.07);}}
.go{position:fixed;inset:0;z-index:0;pointer-events:none;
  background-image:linear-gradient(rgba(255,255,255,.022) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.022) 1px,transparent 1px);
  background-size:54px 54px;}

/* ═══════════════════ SCROLL LINE ═══════════════════ */
.scroll-line-wrap{
  position:fixed;left:26px;top:50%;transform:translateY(-50%);
  z-index:50;display:flex;flex-direction:column;align-items:center;
  height:280px;pointer-events:none;
}
.slt{width:1px;height:100%;background:rgba(255,255,255,.07);position:relative;overflow:hidden;}
.slf{position:absolute;top:0;left:0;width:100%;
  background:linear-gradient(to bottom,var(--cyan),var(--indigo),var(--purple));
  height:0%;transition:height .12s linear;}
.sl-dots{position:absolute;top:0;left:50%;transform:translateX(-50%);
  height:100%;display:flex;flex-direction:column;justify-content:space-between;padding:0;}
.sld{width:7px;height:7px;border-radius:50%;background:rgba(255,255,255,.14);
  border:1px solid rgba(255,255,255,.08);cursor:pointer;pointer-events:all;
  transform:translateX(-3px);transition:all .22s;position:relative;}
.sld.act{background:var(--cyan);border-color:var(--cyan);box-shadow:0 0 10px rgba(34,211,238,.6);}
.sld:hover{transform:translateX(-3px) scale(1.4);}
.sld::after{content:attr(data-l);position:absolute;left:13px;top:50%;transform:translateY(-50%);
  font-family:var(--mono);font-size:8px;color:var(--muted);letter-spacing:.1em;text-transform:uppercase;
  white-space:nowrap;opacity:0;transition:opacity .2s;}
.sld:hover::after,.sld.act::after{opacity:1;}

/* ═══════════════════ NAV ═══════════════════ */
nav{position:fixed;top:0;left:0;right:0;z-index:200;height:58px;
  display:flex;align-items:center;justify-content:space-between;padding:0 52px;
  background:rgba(5,7,12,.88);backdrop-filter:blur(24px) saturate(180%);
  border-bottom:1px solid var(--bdr);}
.logo{font-family:var(--mono);font-size:13px;font-weight:500;color:var(--cyan);text-decoration:none;letter-spacing:.04em;}
.logo span{color:var(--muted);}
.navul{display:flex;gap:28px;list-style:none;}
.navul a{font-family:var(--mono);font-size:10px;color:var(--muted);text-decoration:none;
  letter-spacing:.12em;text-transform:uppercase;transition:color .2s;}
.navul a:hover,.navul a.act{color:var(--text);}
.nav-dl{display:flex;align-items:center;gap:6px;padding:6px 15px;
  border:1px solid rgba(34,211,238,.38);border-radius:6px;color:var(--cyan);
  font-family:var(--mono);font-size:10px;font-weight:500;letter-spacing:.08em;
  text-transform:uppercase;text-decoration:none;transition:all .22s;}
.nav-dl:hover{background:rgba(34,211,238,.08);box-shadow:0 0 20px rgba(34,211,238,.15);}
.nav-dl svg{width:12px;height:12px;}

/* ═══════════════════ HERO ═══════════════════ */
#home{position:relative;z-index:1;min-height:100vh;
  display:grid;grid-template-columns:1fr 420px;gap:40px;align-items:center;
  max-width:1160px;margin:0 auto;padding:100px 52px 80px;}
.hero-left{display:flex;flex-direction:column;}
.eyebrow{display:inline-flex;align-items:center;gap:8px;
  font-family:var(--mono);font-size:10px;color:var(--cyan);
  letter-spacing:.16em;text-transform:uppercase;margin-bottom:18px;}
.eyebrow::before{content:'';width:6px;height:6px;background:var(--cyan);border-radius:50%;animation:blink 2s ease infinite;}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.15}}
h1.name{font-family:'Syne',sans-serif;font-size:clamp(50px,7.5vw,88px);
  font-weight:800;line-height:.92;letter-spacing:-.035em;margin-bottom:16px;}
h1.name .w1{display:block;color:#fff;}
h1.name .w2{display:block;
  background:linear-gradient(110deg,var(--indigo) 0%,var(--cyan) 55%,var(--green) 100%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.role{font-family:var(--mono);font-size:12px;color:var(--muted2);
  letter-spacing:.04em;display:flex;flex-wrap:wrap;align-items:center;gap:6px;margin-bottom:20px;}
.role .hl{color:var(--cyan);}.role .dot{color:rgba(255,255,255,.15);}
.bio{font-size:15px;font-weight:300;line-height:1.82;color:var(--muted2);max-width:490px;margin-bottom:28px;}
.actions{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:34px;}
.btn{display:inline-flex;align-items:center;gap:7px;padding:10px 20px;border-radius:9px;
  font-family:var(--mono);font-size:11px;font-weight:500;
  text-decoration:none;transition:all .22s;white-space:nowrap;cursor:pointer;border:none;}
.btn svg{width:14px;height:14px;flex-shrink:0;}
.btn-p{background:linear-gradient(135deg,var(--indigo),var(--cyan));color:#030408;}
.btn-p:hover{opacity:.84;transform:translateY(-1px);box-shadow:0 8px 28px rgba(34,211,238,.28);}
.btn-g{border:1px solid var(--bdr2);color:var(--text);background:transparent;}
.btn-g:hover{border-color:var(--cyan);color:var(--cyan);background:rgba(34,211,238,.05);}
.hero-right{display:flex;flex-direction:column;gap:11px;}
.stat-row{display:grid;grid-template-columns:1fr 1fr;gap:11px;}
.stat-c{background:var(--surf);border:1px solid var(--bdr);border-radius:var(--r);
  padding:16px 20px;transition:border-color .2s;}
.stat-c:hover{border-color:var(--bdr2);}
.stat-v{font-family:'Syne',sans-serif;font-size:30px;font-weight:800;color:var(--cyan);line-height:1;}
.stat-l{font-family:var(--mono);font-size:9px;color:var(--muted);letter-spacing:.1em;text-transform:uppercase;margin-top:4px;}

/* ═══════════════════ TERMINAL COMPONENT ═══════════════════ */
.term-wrap{background:#060a12;border:1px solid var(--bdr);border-radius:var(--r);overflow:hidden;display:flex;flex-direction:column;font-family:var(--mono);font-size:11.5px;}
.term-bar{display:flex;align-items:center;gap:6px;padding:9px 14px;
  background:rgba(255,255,255,.03);border-bottom:1px solid var(--bdr);flex-shrink:0;}
.td{width:11px;height:11px;border-radius:50%;}.td.r{background:#ff5f57;}.td.y{background:#febc2e;}.td.g{background:#28c840;}
.term-title{font-size:10px;color:var(--muted);margin-left:6px;letter-spacing:.06em;}
.tbadge{margin-left:auto;font-size:9px;letter-spacing:.08em;text-transform:uppercase;padding:2px 8px;border-radius:100px;}
.tb-sim{background:rgba(251,191,36,.1);color:var(--amber);border:1px solid rgba(251,191,36,.2);}
.tb-live{background:rgba(52,211,153,.1);color:var(--green);border:1px solid rgba(52,211,153,.2);}
.term-output{flex:1;overflow-y:auto;padding:14px 16px;display:flex;flex-direction:column;gap:2px;
  scrollbar-width:thin;scrollbar-color:rgba(255,255,255,.08) transparent;}
.term-output::-webkit-scrollbar{width:3px;}
.term-output::-webkit-scrollbar-thumb{background:rgba(255,255,255,.08);border-radius:2px;}
.tl{display:flex;align-items:flex-start;line-height:1.7;white-space:pre-wrap;word-break:break-all;}
.tl.cmd .tp{color:var(--indigo);}.tl.cmd .tv{color:var(--text);}
.tl.out .tv{color:var(--muted2);}.tl.ok  .tv{color:var(--green);}
.tl.err .tv{color:var(--red);} .tl.hl  .tv{color:var(--cyan);}
.tl.dim .tv{color:var(--muted);font-style:italic;}.tl.key .tv{color:var(--amber);}
.tl.blank{height:8px;display:block;}
.tbar-s{display:inline-block;height:10px;border-radius:2px;vertical-align:middle;margin:0 1px;}
.tp{flex-shrink:0;user-select:none;}
.term-input-row{display:flex;align-items:center;padding:10px 16px;border-top:1px solid var(--bdr);flex-shrink:0;gap:6px;}
.term-input-row .tp{color:var(--indigo);}
.term-input{background:transparent;border:none;outline:none;color:var(--text);font-family:var(--mono);font-size:11.5px;flex:1;caret-color:var(--cyan);}
.term-input::placeholder{color:var(--muted);opacity:.4;}

/* ═══════════════════ SECTIONS ═══════════════════ */
.section{position:relative;z-index:1;}
.wrap{max-width:1160px;margin:0 auto;padding:80px 52px;}
.divider{border:none;border-top:1px solid var(--bdr);position:relative;z-index:1;}
.sec-lbl{font-family:var(--mono);font-size:9px;color:var(--cyan);
  letter-spacing:.2em;text-transform:uppercase;margin-bottom:10px;
  display:flex;align-items:center;gap:10px;}
.sec-lbl::after{content:'';height:1px;width:60px;background:var(--bdr);}
.sec-h{font-family:'Syne',sans-serif;font-size:clamp(26px,4vw,42px);
  font-weight:800;line-height:1.05;letter-spacing:-.025em;margin-bottom:40px;}
.sec-h em{font-style:normal;background:linear-gradient(90deg,var(--indigo),var(--cyan));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}

/* ═══════════════════ APPLE WATCH GRID ═══════════════════ */
#projects .project-arena{
  display:grid;grid-template-columns:1fr 560px;gap:48px;align-items:center;min-height:580px;
}
.proj-info-panel{display:flex;flex-direction:column;justify-content:center;min-height:400px;}
.pip-default{display:flex;flex-direction:column;gap:10px;}
.pip-hint{font-family:var(--mono);font-size:10px;color:var(--muted);letter-spacing:.1em;
  text-transform:uppercase;display:flex;align-items:center;gap:8px;margin-bottom:6px;}
.pip-hint::before{content:'';width:24px;height:1px;background:var(--bdr2);}
.pip-arrows{display:flex;gap:6px;margin-top:4px;}
.pip-arrow{width:28px;height:28px;border-radius:50%;background:rgba(255,255,255,.04);
  border:1px solid var(--bdr);display:flex;align-items:center;justify-content:center;
  animation:arrowbounce 2s ease-in-out infinite;}
.pip-arrow:nth-child(2){animation-delay:.3s;opacity:.7;}
.pip-arrow:nth-child(3){animation-delay:.6s;opacity:.4;}
@keyframes arrowbounce{0%,100%{transform:translateX(0);}50%{transform:translateX(4px);}}

.pip-active{display:none;flex-direction:column;gap:0;}
.pip-active.show{display:flex;}
.pip-a-num{font-family:var(--mono);font-size:9px;color:var(--muted);letter-spacing:.14em;text-transform:uppercase;margin-bottom:10px;}
.pip-a-icon{font-size:36px;margin-bottom:12px;}
.pip-a-name{font-family:'Syne',sans-serif;font-size:32px;font-weight:800;color:var(--text);
  line-height:1.05;letter-spacing:-.02em;margin-bottom:6px;}
.pip-a-sub{font-family:var(--mono);font-size:10px;color:var(--cyan);letter-spacing:.1em;
  text-transform:uppercase;margin-bottom:14px;}
.pip-a-desc{font-size:14px;line-height:1.78;color:var(--muted2);margin-bottom:18px;max-width:420px;}
.pip-a-tags{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:22px;}
.pip-a-actions{display:flex;gap:8px;flex-wrap:wrap;}
.pip-open{display:inline-flex;align-items:center;gap:6px;padding:9px 18px;
  background:linear-gradient(135deg,var(--indigo),var(--cyan));border-radius:8px;
  font-family:var(--mono);font-size:10px;font-weight:600;color:#030408;
  text-decoration:none;cursor:pointer;border:none;transition:all .22s;}
.pip-open:hover{opacity:.85;transform:translateY(-1px);}
.pip-link{display:inline-flex;align-items:center;gap:5px;padding:9px 14px;
  border:1px solid var(--bdr2);border-radius:8px;font-family:var(--mono);
  font-size:10px;color:var(--muted2);text-decoration:none;transition:all .2s;}
.pip-link:hover{border-color:var(--cyan);color:var(--cyan);}
.pip-link svg{width:11px;height:11px;}
.pip-live-badge{display:inline-flex;align-items:center;gap:5px;padding:3px 10px;
  background:rgba(52,211,153,.09);border:1px solid rgba(52,211,153,.25);
  border-radius:100px;font-family:var(--mono);font-size:9px;color:var(--green);
  letter-spacing:.08em;width:fit-content;margin-bottom:12px;}
.pip-live-badge::before{content:'';width:5px;height:5px;background:var(--green);border-radius:50%;animation:blink 1.5s ease infinite;}

/* Floating bubble grid — no bezel, pure space */
.watchface-wrap{perspective:900px;display:flex;align-items:center;justify-content:center;}
.watchface-bezel{
  width:540px;height:540px;
  display:flex;align-items:center;justify-content:center;
  position:relative;
}
.watchface{
  width:520px;height:520px;
  position:relative;
  transform-style:preserve-3d;
  transition:transform .14s ease;
}
/* ── Bubble defaults: soft, faded, background presence ── */
.wbubble{
  position:absolute;border-radius:50%;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  cursor:pointer;transform-style:preserve-3d;user-select:none;
  /* Everything starts dim and desaturated — sleeping in the background */
  opacity:.42;
  filter:saturate(.45) brightness(.7);
  transition:opacity .38s ease, filter .38s ease, transform .22s ease, box-shadow .38s ease;
}
.wbubble.feat{
  /* Center project stays slightly more visible — it's always the anchor */
  opacity:.62;
  filter:saturate(.6) brightness(.8);
}

/* ── Hovering state: darken ALL siblings, spotlight the one touched ── */
.watchface.is-hovering .wbubble{
  opacity:.1;
  filter:saturate(.15) brightness(.3) blur(.5px);
  transition:opacity .28s ease, filter .28s ease, transform .22s ease, box-shadow .28s ease;
}
.watchface.is-hovering .wbubble.active{
  opacity:1;
  filter:saturate(1.05) brightness(1.12);
  box-shadow:0 0 40px rgba(255,255,255,.12), 0 0 80px rgba(255,255,255,.06);
}

/* ── Inner bubble shell ── */
.wbubble-inner{
  width:100%;height:100%;border-radius:50%;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  position:relative;overflow:hidden;
  transition:transform .22s cubic-bezier(.34,1.56,.64,1);
}
.wbubble-inner::after{
  content:'';position:absolute;inset:0;border-radius:50%;
  background:radial-gradient(ellipse at 30% 22%,rgba(255,255,255,.28) 0%,transparent 60%);
  pointer-events:none;
}
/* Active bubble pops forward */
.wbubble.active .wbubble-inner{
  transform:scale(1.11) translateZ(12px);
}

/* ── Icon & name: hidden until bubble is active or featured ── */
.wbubble .wb-icon{font-size:0;line-height:1;pointer-events:none;
  transition:font-size .24s cubic-bezier(.34,1.56,.64,1), opacity .2s;}
.wbubble .wb-name{font-family:var(--mono);font-size:0;font-weight:500;
  color:rgba(255,255,255,.92);letter-spacing:.04em;pointer-events:none;
  transition:font-size .24s cubic-bezier(.34,1.56,.64,1), opacity .2s;
  text-align:center;max-width:80%;line-height:1.2;margin-top:0;}
.wbubble.active .wb-icon{font-size:28px;}
.wbubble.active .wb-name{font-size:10px;margin-top:4px;}
/* Featured (center) always shows */
.wbubble.feat .wb-icon{font-size:34px;}
.wbubble.feat .wb-name{font-size:11px;margin-top:5px;}

/* ── Subtle breathing pulse on center bubble ── */
.wbubble.feat .wbubble-inner{
  animation:breathe 4s ease-in-out infinite;
}
.watchface.is-hovering .wbubble.feat.active .wbubble-inner{
  animation:none;
}
@keyframes breathe{
  0%,100%{transform:scale(1);}
  50%{transform:scale(1.04);}
}

/* ═══════════════════ LIST VIEW (card grid) ═══════════════════ */
.list-toggle{display:flex;align-items:center;gap:10px;margin-bottom:32px;margin-top:16px;}
.lt-btn{font-family:var(--mono);font-size:10px;color:var(--muted);letter-spacing:.1em;text-transform:uppercase;
  display:flex;align-items:center;gap:7px;padding:7px 14px;border:1px solid var(--bdr);
  border-radius:7px;cursor:pointer;background:transparent;transition:all .2s;}
.lt-btn:hover,.lt-btn.act{border-color:var(--bdr2);color:var(--text);}
.lt-btn.act{border-color:var(--cyan);color:var(--cyan);}
.lt-btn svg{width:12px;height:12px;}
#list-view{display:none;}
#list-view.show{display:grid;grid-template-columns:repeat(2,1fr);gap:18px;}

/* classic project card */
.pc{background:var(--surf);border:1px solid var(--bdr);border-radius:16px;
  padding:26px;position:relative;overflow:hidden;display:flex;flex-direction:column;
  transition:border-color .35s,transform .35s,box-shadow .35s;cursor:pointer;}
.pc::after{content:'';position:absolute;inset:0;pointer-events:none;z-index:0;
  background:radial-gradient(380px circle at var(--mx,50%) var(--my,50%),rgba(34,211,238,.055),transparent 55%);
  opacity:0;transition:opacity .4s;}
.pc:hover{border-color:var(--bdr2);transform:translateY(-3px);box-shadow:0 16px 50px rgba(0,0,0,.5);}
.pc:hover::after{opacity:1;}
.pc>*{position:relative;z-index:1;}
.pc-feat-card{grid-column:1/-1;display:grid;grid-template-columns:1fr 1fr;gap:28px;align-items:start;}
.pc-feat-card .pc-l{display:flex;flex-direction:column;}
.pc-feat-card .pc-r{background:rgba(5,7,12,.7);border:1px solid var(--bdr);border-radius:10px;padding:20px;align-self:stretch;}
.pnum{font-family:var(--mono);font-size:9px;color:var(--muted);letter-spacing:.13em;margin-bottom:12px;}
.picon{font-size:24px;width:48px;height:48px;
  background:linear-gradient(135deg,rgba(129,140,248,.14),rgba(34,211,238,.09));
  border:1px solid var(--bdr2);border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:14px;}
.pname{font-family:'Syne',sans-serif;font-size:18px;font-weight:700;color:var(--text);margin-bottom:5px;line-height:1.2;}
.psub{font-family:var(--mono);font-size:9px;color:var(--cyan);letter-spacing:.1em;text-transform:uppercase;margin-bottom:10px;}
.pdesc{font-size:13px;line-height:1.75;color:rgba(114,137,168,.85);margin-bottom:14px;flex:1;}
.pbullets{list-style:none;display:flex;flex-direction:column;gap:6px;margin-bottom:18px;}
.pbullets li{font-size:12px;color:rgba(122,143,170,.8);line-height:1.5;display:flex;align-items:flex-start;gap:8px;}
.pbullets li::before{content:'›';color:var(--cyan);font-weight:700;flex-shrink:0;}
.ptags{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:16px;}
.tag{font-family:var(--mono);font-size:9px;font-weight:500;padding:3px 9px;border-radius:4px;letter-spacing:.04em;}
.tc{background:rgba(34,211,238,.09);color:var(--cyan);border:1px solid rgba(34,211,238,.16);}
.ti{background:rgba(129,140,248,.09);color:var(--indigo);border:1px solid rgba(129,140,248,.16);}
.tg{background:rgba(52,211,153,.09);color:var(--green);border:1px solid rgba(52,211,153,.16);}
.ta{background:rgba(251,191,36,.09);color:var(--amber);border:1px solid rgba(251,191,36,.16);}
.tp2{background:rgba(244,114,182,.09);color:var(--pink);border:1px solid rgba(244,114,182,.16);}
.plinks{display:flex;gap:7px;flex-wrap:wrap;}
.pl{display:inline-flex;align-items:center;gap:5px;padding:6px 13px;
  border:1px solid var(--bdr2);border-radius:7px;font-family:var(--mono);
  font-size:9px;color:var(--muted2);text-decoration:none;letter-spacing:.05em;transition:all .2s;}
.pl:hover{border-color:var(--cyan);color:var(--cyan);}
.pl svg{width:11px;height:11px;}
.pl-p{background:linear-gradient(135deg,var(--indigo),var(--cyan));color:#030408;border:none;font-weight:600;}
.pl-p:hover{opacity:.84;color:#030408;}
.live-badge{display:inline-flex;align-items:center;gap:5px;padding:3px 10px;
  background:rgba(52,211,153,.08);border:1px solid rgba(52,211,153,.22);
  border-radius:100px;font-family:var(--mono);font-size:9px;color:var(--green);
  letter-spacing:.08em;margin-bottom:12px;width:fit-content;}
.live-badge::before{content:'';width:5px;height:5px;background:var(--green);border-radius:50%;animation:blink 1.5s ease infinite;}
.arch-title{font-family:var(--mono);font-size:9px;color:var(--muted);letter-spacing:.14em;text-transform:uppercase;margin-bottom:10px;}
.arch-row{display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid var(--bdr);}
.arch-row:last-child{border-bottom:none;}
.anum{font-family:var(--mono);font-size:10px;color:var(--indigo);width:18px;flex-shrink:0;}
.astep{font-size:11px;color:var(--muted2);flex:1;}
.atech{font-family:var(--mono);font-size:9px;color:var(--green);letter-spacing:.05em;}
.pc-zoom-hint{position:absolute;bottom:14px;right:14px;z-index:2;
  font-family:var(--mono);font-size:8px;color:var(--muted);letter-spacing:.1em;text-transform:uppercase;
  display:flex;align-items:center;gap:5px;opacity:0;transition:opacity .3s;}
.pc:hover .pc-zoom-hint{opacity:1;}
.pc-zoom-hint svg{width:10px;height:10px;}

/* ═══════════════════ ABOUT ═══════════════════ */
.about-bg{background:rgba(255,255,255,.01);border-top:1px solid var(--bdr);border-bottom:1px solid var(--bdr);}
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:50px;align-items:start;}
.abio{font-size:14px;line-height:1.85;color:rgba(114,137,168,.9);}
.abio p+p{margin-top:14px;}.abio strong{color:var(--text);font-weight:500;}
.tl-wrap{display:flex;flex-direction:column;}
.tli{display:flex;gap:16px;padding-bottom:22px;position:relative;}
.tli:not(:last-child)::after{content:'';position:absolute;left:7px;top:17px;width:1px;bottom:0;background:var(--bdr);}
.tldot{width:16px;height:16px;flex-shrink:0;border-radius:50%;border:2px solid var(--indigo);background:var(--bg);margin-top:2px;position:relative;z-index:1;}
.tldot.now{background:var(--cyan);border-color:var(--cyan);}
.tdate{font-family:var(--mono);font-size:9px;color:var(--muted);letter-spacing:.08em;text-transform:uppercase;margin-bottom:2px;}
.trole{font-family:'Syne',sans-serif;font-size:13px;font-weight:700;color:var(--text);margin-bottom:2px;}
.torg{font-size:11px;color:var(--cyan);margin-bottom:4px;}
.tdesc{font-size:12px;color:var(--muted);line-height:1.6;}

/* ═══════════════════ SKILLS — Icon Grid (benscott.dev style) ═══════════════════ */
#skills .skills-intro{font-size:15px;line-height:1.8;color:var(--muted2);max-width:560px;margin-bottom:44px;}
.skills-categories{display:flex;flex-direction:column;gap:36px;}
.skill-cat-label{font-family:var(--mono);font-size:9px;color:var(--muted);letter-spacing:.18em;
  text-transform:uppercase;margin-bottom:16px;display:flex;align-items:center;gap:10px;}
.skill-cat-label::after{content:'';flex:1;height:1px;background:var(--bdr);}
.skill-icons-row{display:flex;flex-wrap:wrap;gap:12px;}
.skill-icon-badge{
  display:flex;flex-direction:column;align-items:center;gap:8px;
  width:76px;cursor:default;
  animation:fadeSlideUp .5s ease both;
}
@keyframes fadeSlideUp{from{opacity:0;transform:translateY(16px);}to{opacity:1;transform:none;}}
.sib-circle{
  width:60px;height:60px;border-radius:16px;
  display:flex;align-items:center;justify-content:center;
  font-size:26px;line-height:1;
  border:1px solid var(--bdr);
  background:rgba(255,255,255,.03);
  transition:all .25s;
  position:relative;overflow:hidden;
}
.sib-circle::after{content:'';position:absolute;inset:0;border-radius:16px;
  background:radial-gradient(ellipse at 35% 25%,rgba(255,255,255,.12),transparent 60%);
  opacity:0;transition:opacity .25s;}
.skill-icon-badge:hover .sib-circle{transform:translateY(-3px);box-shadow:0 8px 24px rgba(0,0,0,.4);}
.skill-icon-badge:hover .sib-circle::after{opacity:1;}
.sib-name{font-family:var(--mono);font-size:9px;color:var(--muted2);letter-spacing:.06em;text-align:center;text-transform:uppercase;}

/* ═══════════════════ CERTS ═══════════════════ */
.cert-bg{background:rgba(255,255,255,.01);border-top:1px solid var(--bdr);}
.cgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:13px;}
.cc{background:rgba(5,7,12,.6);border:1px solid var(--bdr);border-radius:var(--r);
  padding:18px;display:flex;flex-direction:column;gap:6px;transition:border-color .2s,transform .2s;}
.cc:hover{border-color:var(--bdr2);transform:translateY(-2px);}
.cico{font-size:18px;}.cname{font-family:'Syne',sans-serif;font-size:13px;font-weight:700;color:var(--text);}
.corg{font-size:11px;color:var(--muted);}
.cbadge{display:inline-block;width:fit-content;font-family:var(--mono);font-size:8px;
  letter-spacing:.1em;text-transform:uppercase;padding:3px 8px;border-radius:100px;}
.cb-done{background:rgba(52,211,153,.09);color:var(--green);border:1px solid rgba(52,211,153,.2);}
.cb-wip{background:rgba(251,191,36,.09);color:var(--amber);border:1px solid rgba(251,191,36,.2);}

/* ═══════════════════ CONTACT ═══════════════════ */
.contact-bg{background:var(--bg);border-top:1px solid var(--bdr);}
.cta{text-align:center;padding:60px 0;}
.cta-pre{font-family:var(--mono);font-size:9px;color:var(--cyan);letter-spacing:.2em;text-transform:uppercase;margin-bottom:14px;}
.cta-h{font-family:'Syne',sans-serif;font-size:clamp(28px,5vw,48px);font-weight:800;line-height:1.05;letter-spacing:-.025em;margin-bottom:12px;}
.cta-h em{font-style:normal;background:linear-gradient(90deg,var(--indigo),var(--cyan));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.cta-sub{font-size:14px;color:var(--muted);max-width:360px;margin:0 auto 28px;}
.cta-acts{display:flex;justify-content:center;flex-wrap:wrap;gap:10px;}
footer{border-top:1px solid var(--bdr);padding:20px 52px;display:flex;align-items:center;justify-content:space-between;}
.fm{font-family:var(--mono);font-size:10px;color:var(--muted);letter-spacing:.03em;}
.flinks{display:flex;gap:18px;list-style:none;}
.flinks a{font-family:var(--mono);font-size:10px;color:var(--muted);text-decoration:none;transition:color .2s;}
.flinks a:hover{color:var(--cyan);}

/* ═══════════════════ MODAL (Tabbed) ═══════════════════ */
.m-overlay{position:fixed;inset:0;z-index:300;background:rgba(3,4,8,.93);
  backdrop-filter:blur(18px);display:flex;align-items:center;justify-content:center;
  padding:20px;opacity:0;pointer-events:none;transition:opacity .28s;}
.m-overlay.open{opacity:1;pointer-events:all;}
.m-box{width:100%;max-width:1080px;max-height:90vh;
  background:#070b14;border:1px solid var(--bdr2);border-radius:18px;
  overflow:hidden;display:flex;flex-direction:column;
  transform:translateY(22px)scale(.98);transition:transform .32s cubic-bezier(.2,.8,.2,1);}
.m-overlay.open .m-box{transform:none;}
.m-hdr{display:flex;align-items:center;justify-content:space-between;
  padding:15px 24px;border-bottom:1px solid var(--bdr);flex-shrink:0;}
.m-hdr-l{display:flex;align-items:center;gap:12px;}
.m-hico{font-size:20px;width:38px;height:38px;
  background:linear-gradient(135deg,rgba(129,140,248,.18),rgba(34,211,238,.12));
  border:1px solid var(--bdr2);border-radius:9px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.m-hname{font-family:'Syne',sans-serif;font-size:16px;font-weight:800;color:var(--text);}
.m-hsub{font-family:var(--mono);font-size:9px;color:var(--cyan);letter-spacing:.09em;text-transform:uppercase;margin-top:2px;}
.m-close{width:32px;height:32px;background:var(--surf2);border:1px solid var(--bdr);
  border-radius:7px;color:var(--muted);font-size:16px;cursor:pointer;
  display:flex;align-items:center;justify-content:center;transition:all .2s;}
.m-close:hover{border-color:var(--bdr2);color:var(--text);}
.m-tabs{display:flex;padding:0 24px;border-bottom:1px solid var(--bdr);flex-shrink:0;}
.m-tab{font-family:var(--mono);font-size:10px;color:var(--muted);letter-spacing:.1em;
  text-transform:uppercase;padding:11px 16px;cursor:pointer;border-bottom:2px solid transparent;
  transition:all .2s;user-select:none;}
.m-tab:hover{color:var(--text);}
.m-tab.act{color:var(--cyan);border-bottom-color:var(--cyan);}
.m-panels{flex:1;overflow:hidden;position:relative;}
.m-panel{position:absolute;inset:0;overflow-y:auto;opacity:0;pointer-events:none;transition:opacity .18s;}
.m-panel.act{opacity:1;pointer-events:all;}
.m-2col{display:grid;grid-template-columns:320px 1fr;height:100%;}
.m-left{padding:20px 22px;border-right:1px solid var(--bdr);overflow-y:auto;display:flex;flex-direction:column;gap:16px;}
.m-right{overflow-y:auto;}
.m-sect{padding:16px 22px;border-bottom:1px solid var(--bdr);}
.m-sect:last-child{border-bottom:none;}
.mlbl{font-family:var(--mono);font-size:9px;color:var(--muted);letter-spacing:.14em;text-transform:uppercase;
  margin-bottom:9px;display:flex;align-items:center;gap:8px;}
.mlbl::after{content:'';flex:1;height:1px;background:var(--bdr);}
.m-txt{font-size:13px;line-height:1.78;color:var(--muted2);}
.m-buls{list-style:none;display:flex;flex-direction:column;gap:6px;}
.m-buls li{font-size:12px;color:var(--muted2);line-height:1.5;display:flex;align-items:flex-start;gap:7px;}
.m-buls li::before{content:'›';color:var(--cyan);font-weight:700;flex-shrink:0;}
.metrics-g{display:grid;grid-template-columns:repeat(2,1fr);gap:8px;}
.mc{background:rgba(255,255,255,.03);border:1px solid var(--bdr);border-radius:9px;padding:12px 14px;}
.mc-v{font-family:'Syne',sans-serif;font-size:20px;font-weight:800;color:var(--cyan);}
.mc-l{font-family:var(--mono);font-size:9px;color:var(--muted);letter-spacing:.1em;text-transform:uppercase;margin-top:3px;}
.m-arch-row{display:flex;align-items:flex-start;gap:12px;padding:10px 0;border-bottom:1px solid var(--bdr);}
.m-arch-row:last-child{border-bottom:none;}
.m-an{font-family:var(--mono);font-size:10px;color:var(--indigo);width:22px;flex-shrink:0;padding-top:1px;}
.m-aw{display:flex;flex-direction:column;flex:1;}
.m-as{font-size:12px;color:var(--text);font-weight:500;}
.m-ad{font-size:11px;color:var(--muted2);margin-top:2px;line-height:1.5;}
.m-at{font-family:var(--mono);font-size:9px;color:var(--green);letter-spacing:.06em;margin-top:3px;}
.code-fb{font-family:var(--mono);font-size:9px;color:var(--muted);
  letter-spacing:.07em;padding:8px 18px;background:rgba(255,255,255,.025);
  border-bottom:1px solid var(--bdr);display:flex;align-items:center;gap:7px;}
.code-fb::before{content:'';width:7px;height:7px;background:var(--green);border-radius:50%;display:inline-block;}
.code-blk{background:#030508;padding:14px 18px;overflow-x:auto;}
.code-blk pre{font-family:var(--mono);font-size:11px;line-height:1.9;color:#7a91b0;white-space:pre;}
.ck{color:var(--indigo);}.cs{color:var(--green);}.cn{color:var(--amber);}
.cc2{color:#3a5070;font-style:italic;}.cf{color:var(--cyan);}.ca{color:var(--pink);}
.m-tryit{padding:18px 22px;display:flex;flex-direction:column;height:100%;gap:10px;}
.tryit-hint{font-family:var(--mono);font-size:10px;color:var(--muted);line-height:1.8;}
.tryit-hint .cmd-ex{color:var(--indigo);}

/* ═══════════════════ FADE-IN ═══════════════════ */
.fi{opacity:0;transform:translateY(16px);transition:opacity .55s ease,transform .55s ease;}
.fi.v{opacity:1;transform:none;}
.d1{transition-delay:.07s}.d2{transition-delay:.14s}.d3{transition-delay:.21s}.d4{transition-delay:.28s}

/* ═══════════════════ RESPONSIVE ═══════════════════ */
@media(max-width:1020px){
  nav{padding:0 20px;}.navul{display:none;}
  .scroll-line-wrap{display:none;}
  #home{grid-template-columns:1fr;padding:100px 22px 80px;}.hero-right{display:none;}
  .wrap{padding:60px 22px;}
  #projects .project-arena{grid-template-columns:1fr;}.watchface-wrap{display:none;}
  .pip-default{display:none;}.pip-active{display:flex!important;padding-bottom:20px;}
  #list-view{display:grid!important;grid-template-columns:1fr;}
  .pc-feat-card{grid-column:span 1;display:flex;flex-direction:column;}.pc-feat-card .pc-r{display:none;}
  .about-grid{grid-template-columns:1fr;}
  .sgrid,.cgrid{grid-template-columns:repeat(2,1fr);}
  footer{flex-direction:column;gap:12px;padding:18px;text-align:center;}
  .m-2col{grid-template-columns:1fr;}.m-left{border-right:none;border-bottom:1px solid var(--bdr);}
}
</style>
</head>
<body>

<!-- Aurora + grid -->
<div class="ab"><div class="bl b1"></div><div class="bl b2"></div><div class="bl b3"></div></div>
<div class="go"></div>

<!-- Scroll progress line -->
<div class="scroll-line-wrap">
  <div class="slt">
    <div class="slf" id="slf"></div>
    <div class="sl-dots">
      <div class="sld act" data-s="home" data-l="Home"></div>
      <div class="sld" data-s="projects" data-l="Projects"></div>
      <div class="sld" data-s="about" data-l="About"></div>
      <div class="sld" data-s="skills" data-l="Skills"></div>
      <div class="sld" data-s="contact" data-l="Contact"></div>
    </div>
  </div>
</div>

<!-- NAV -->
<nav>
  <a href="#home" class="logo">RS<span>.dev</span></a>
  <ul class="navul">
    <li><a href="#home">Home</a></li>
    <li><a href="#projects">Projects</a></li>
    <li><a href="#about">About</a></li>
    <li><a href="#skills">Skills</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
  <a href="./Ryan_Sokolowsky_Resume.pdf" download class="nav-dl">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>Resume
  </a>
</nav>

<!-- HERO -->
<section id="home" class="section">
  <div id="home" style="position:relative;z-index:1;display:grid;grid-template-columns:1fr 420px;gap:40px;align-items:center;max-width:1160px;margin:0 auto;min-height:100vh;padding:100px 52px 80px;">
    <div class="hero-left">
      <div class="eyebrow">Available for opportunities</div>
      <h1 class="name"><span class="w1">Ryan</span><span class="w2">Sokolowsky</span></h1>
      <p class="role"><span class="hl">AI Solutions</span><span class="dot">·</span>Automation Engineer<span class="dot">·</span><span class="hl">Draper, UT</span></p>
      <p class="bio">I build intelligent systems that automate the hard stuff — multi-agent LLM pipelines, autonomous drones, ML inference systems. Full stack: model layer to hardware.</p>
      <div class="actions">
        <a href="#projects" class="btn btn-p"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="5 3 19 12 5 21 5 3"/></svg>Explore Projects</a>
        <a href="https://github.com/RSokolowskyDev" target="_blank" rel="noopener" class="btn btn-g"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>GitHub</a>
        <a href="mailto:ryan.sokolowsky@gmail.com" class="btn btn-g"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 7 10-7"/></svg>Email</a>
      </div>
    </div>
    <div class="hero-right">
      <div class="stat-row">
        <div class="stat-c"><div class="stat-v">7+</div><div class="stat-l">Projects</div></div>
        <div class="stat-c"><div class="stat-v">25%</div><div class="stat-l">Cost ↓</div></div>
      </div>
      <div class="stat-c"><div class="stat-v">16×</div><div class="stat-l">Team Lead</div></div>
      <div class="term-wrap" style="flex:1;">
        <div class="term-bar">
          <div class="td r"></div><div class="td y"></div><div class="td g"></div>
          <span class="term-title">ryan@portfolio</span>
          <span class="tbadge tb-live" style="margin-left:auto;">Interactive</span>
        </div>
        <div class="term-output" id="hero-out"></div>
        <div class="term-input-row">
          <span class="tp">$&nbsp;</span>
          <input class="term-input" id="hero-inp" type="text" autocomplete="off" spellcheck="false" placeholder="type help"/>
        </div>
      </div>
    </div>
    <div style="position:absolute;bottom:28px;left:50%;transform:translateX(-50%);
      font-family:var(--mono);font-size:9px;color:var(--muted);letter-spacing:.12em;
      text-transform:uppercase;display:flex;flex-direction:column;align-items:center;gap:4px;
      animation:bob 2.6s ease infinite;">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>scroll
    </div>
    <style>@keyframes bob{0%,100%{transform:translateX(-50%)translateY(0)}50%{transform:translateX(-50%)translateY(5px)}}</style>
  </div>
</section>

<!-- PROJECTS -->
<hr class="divider"/>
<section id="projects" class="section" style="background:rgba(5,7,12,.4);">
  <div class="wrap">
    <div class="sec-lbl">// 01 — Work</div>
    <h2 class="sec-h">Featured <em>Projects</em></h2>

    <!-- Watch Face + Info Panel -->
    <div class="project-arena">
      <!-- Left: Project Info Panel -->
      <div class="proj-info-panel">
        <div class="pip-default" id="pip-default">
          <div class="pip-hint">Hover a bubble to explore</div>
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,.15)" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
          <div class="pip-arrows">
            <div class="pip-arrow"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="var(--cyan)" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></div>
            <div class="pip-arrow"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="var(--indigo)" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></div>
            <div class="pip-arrow"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="var(--muted)" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></div>
          </div>
        </div>
        <div class="pip-active" id="pip-active">
          <div class="pip-a-num" id="pip-num"></div>
          <div class="pip-live-badge" id="pip-live" style="display:none;">Live Demo</div>
          <div class="pip-a-icon" id="pip-icon"></div>
          <div class="pip-a-name" id="pip-name"></div>
          <div class="pip-a-sub" id="pip-sub"></div>
          <div class="pip-a-desc" id="pip-desc"></div>
          <div class="pip-a-tags" id="pip-tags"></div>
          <div class="pip-a-actions" id="pip-acts"></div>
        </div>
      </div>

      <!-- Right: Apple Watch Face -->
      <div class="watchface-wrap" id="wf-wrap">
        <div class="watchface-bezel">
          <div class="watchface" id="watchface">
            <!-- Bubbles injected by JS -->
          </div>
        </div>
      </div>
    </div>

    <!-- View Toggle -->
    <div class="list-toggle">
      <button class="lt-btn" id="lt-list" onclick="toggleListView()">
