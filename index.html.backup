  skills:(_,t)=>t.lines([{t:'blank'},{t:'hl',v:'  Core Stack:'},{t:'out',v:'  Python · CrewAI · FastAPI · LLM APIs'},{t:'out',v:'  AWS · React · ArduPilot · C++ · Lua'},{t:'blank'}]),
  projects:(_,t)=>t.lines([{t:'blank'},{t:'hl',v:'  7 Projects (hover the bubbles below ↓)'},{t:'out',v:'  01 Mark Miller Subaru  — AI lead intel [LIVE]'},{t:'out',v:'  02 Sentinel            — Token optimizer'},{t:'out',v:'  03 Autonomous Drone    — Full hardware build'},{t:'out',v:'  04 Paint Matcher       — ML inference pipeline'},{t:'out',v:'  05 Semantic Layer      — Glass-box AI'},{t:'out',v:'  06 ResumeGen           — Auto PDF generation'},{t:'out',v:'  07 Video Pipeline      — Batch automation'},{t:'blank'}]),
  contact:(_,t)=>t.lines([{t:'blank'},{t:'hl',v:'  Contact:'},{t:'out',v:'  Email  : ryan.sokolowsky@gmail.com'},{t:'out',v:'  Phone  : (331) 298-3934'},{t:'out',v:'  GitHub : github.com/RSokolowskyDev'},{t:'blank'}]),
  hire:(_,t)=>{t.lines([{t:'blank'},{t:'ok',v:'  Opening email...'},{t:'blank'}]);setTimeout(()=>window.location.href='mailto:ryan.sokolowsky@gmail.com',600);},
