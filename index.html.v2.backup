<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Ryan Sokolowsky — AI Solutions Engineer</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=JetBrains+Mono:wght@300;400;500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
<style>
:root{
  --bg:#05070c; --surf:rgba(255,255,255,.032); --surf2:rgba(255,255,255,.055);
  --bdr:rgba(255,255,255,.07); --bdr2:rgba(255,255,255,.13);
  --cyan:#22d3ee; --indigo:#818cf8; --purple:#a855f7;
  --text:#e2e8f4; --muted:#4a5c75; --muted2:#7289a8;
  --green:#34d399; --amber:#fbbf24; --pink:#f472b6; --red:#f87171;
  --r:14px; --mono:'JetBrains Mono',monospace;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;line-height:1.6;overflow-x:hidden;}

.ab{position:fixed;inset:0;z-index:0;overflow:hidden;pointer-events:none;}
.bl{position:absolute;border-radius:50%;filter:blur(110px);opacity:.1;}
.b1{width:700px;height:700px;background:var(--indigo);top:-220px;left:-180px;animation:aura 28s ease-in-out infinite;}
.b2{width:580px;height:580px;background:var(--cyan);bottom:-180px;right:-160px;animation:aura 34s ease-in-out infinite reverse;}
.b3{width:460px;height:460px;background:var(--purple);top:42%;left:43%;animation:aura 22s ease-in-out infinite -11s;}
@keyframes aura{0%,100%{transform:translate(0,0)scale(1);}25%{transform:translate(50px,-65px)scale(1.13);}50%{transform:translate(-35px,55px)scale(.88);}75%{transform:translate(45px,35px)scale(1.07);}}
.go{position:fixed;inset:0;z-index:0;pointer-events:none;background-image:linear-gradient(rgba(255,255,255,.022) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.022) 1px,transparent 1px);background-size:54px 54px;}

.scroll-line-wrap{position:fixed;left:26px;top:50%;transform:translateY(-50%);z-index:50;display:flex;flex-direction:column;align-items:center;height:280px;pointer-events:none;}
.slt{width:1px;height:100%;background:rgba(255,255,255,.07);position:relative;overflow:hidden;}
.slf{position:absolute;top:0;left:0;width:100%;background:linear-gradient(to bottom,var(--cyan),var(--indigo),var(--purple));height:0%;transition:height .12s linear;}
.sl-dots{position:absolute;top:0;left:50%;transform:translateX(-50%);height:100%;display:flex;flex-direction:column;justify-content:space-between;padding:0;}
.sld{width:7px;height:7px;border-radius:50%;background:rgba(255,255,255,.14);border:1px solid rgba(255,255,255,.08);cursor:pointer;pointer-events:all;transform:translateX(-3px);transition:all .22s;position:relative;}
.sld.act{background:var(--cyan);border-color:var(--cyan);box-shadow:0 0 10px rgba(34,211,238,.6);}
.sld:hover{transform:translateX(-3px) scale(1.4);}
.sld::after{content:attr(data-l);position:absolute;left:13px;top:50%;transform:translateY(-50%);font-family:var(--mono);font-size:8px;color:var(--muted);letter-spacing:.1em;text-transform:uppercase;white-space:nowrap;opacity:0;transition:opacity .2s;}
.sld:hover::after,.sld.act::after{opacity:1;}

nav{position:fixed;top:0;left:0;right:0;z-index:200;height:58px;display:flex;align-items:center;justify-content:space-between;padding:0 52px;background:rgba(5,7,12,.88);backdrop-filter:blur(24px) saturate(180%);border-bottom:1px solid var(--bdr);}
.logo{font-family:var(--mono);font-size:13px;font-weight:500;color:var(--cyan);text-decoration:none;letter-spacing:.04em;}
.logo span{color:var(--muted);}
.navul{display:flex;gap:28px;list-style:none;}
.navul a{font-family:var(--mono);font-size:10px;color:var(--muted);text-decoration:none;letter-spacing:.12em;text-transform:uppercase;transition:color .2s;}
.navul a:hover,.navul a.act{color:var(--text);}
.nav-dl{display:flex;align-items:center;gap:6px;padding:6px 15px;border:1px solid rgba(34,211,238,.38);border-radius:6px;color:var(--cyan);font-family:var(--mono);font-size:10px;font-weight:500;letter-spacing:.08em;text-transform:uppercase;text-decoration:none;transition:all .22s;}
.nav-dl:hover{background:rgba(34,211,238,.08);box-shadow:0 0 20px rgba(34,211,238,.15);}
.nav-dl svg{width:12px;height:12px;}

.section{position:relative;z-index:1;}
#home{min-height:100vh;display:grid;grid-template-columns:1fr 420px;gap:40px;align-items:center;max-width:1160px;margin:0 auto;padding:100px 52px 80px;}
.hero-left{display:flex;flex-direction:column;}
.eyebrow{display:inline-flex;align-items:center;gap:8px;font-family:var(--mono);font-size:10px;color:var(--cyan);letter-spacing:.16em;text-transform:uppercase;margin-bottom:18px;}
.eyebrow::before{content:'';width:6px;height:6px;background:var(--cyan);border-radius:50%;animation:blink 2s ease infinite;}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.15}}
h1.name{font-family:'Syne',sans-serif;font-size:clamp(50px,7.5vw,88px);font-weight:800;line-height:.92;letter-spacing:-.035em;margin-bottom:16px;}
h1.name .w1{color:#fff;}
h1.name .w2{background:linear-gradient(110deg,var(--indigo) 0%,var(--cyan) 55%,var(--green) 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.role{font-family:var(--mono);font-size:12px;color:var(--muted2);letter-spacing:.04em;display:flex;flex-wrap:wrap;align-items:center;gap:6px;margin-bottom:20px;}
.role .hl{color:var(--cyan);}
.role .dot{color:rgba(255,255,255,.15);}
.bio{font-size:15px;font-weight:300;line-height:1.82;color:var(--muted2);max-width:490px;margin-bottom:28px;}
.actions{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:34px;}
.btn{display:inline-flex;align-items:center;gap:7px;padding:10px 20px;border-radius:9px;font-family:var(--mono);font-size:11px;font-weight:500;text-decoration:none;transition:all .22s;white-space:nowrap;cursor:pointer;border:none;}
.btn svg{width:14px;height:14px;flex-shrink:0;}
.btn-p{background:linear-gradient(135deg,var(--indigo),var(--cyan));color:#030408;}
.btn-p:hover{opacity:.84;transform:translateY(-1px);box-shadow:0 8px 28px rgba(34,211,238,.28);}
.btn-g{border:1px solid var(--bdr);color:var(--text);}
.btn-g:hover{background:var(--surf);box-shadow:0 4px 16px rgba(255,255,255,.1);}

.hero-right{display:flex;flex-direction:column;gap:24px;}
.stat-row{display:flex;gap:24px;}
.stat-c{display:flex;flex-direction:column;gap:6px;}
.stat-v{font-size:28px;font-weight:700;background:linear-gradient(135deg,var(--indigo),var(--cyan));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.stat-l{font-family:var(--mono);font-size:9px;color:var(--muted);letter-spacing:.1em;text-transform:uppercase;}

.term-wrap{flex:1;display:flex;flex-direction:column;border:1px solid var(--bdr);border-radius:12px;overflow:hidden;background:rgba(0,0,0,.3);}
.term-bar{display:flex;align-items:center;gap:6px;padding:12px 14px;background:rgba(0,0,0,.5);border-bottom:1px solid var(--bdr);}
.td{width:12px;height:12px;border-radius:50%;}
.td.r{background:#ff5f57;}
.td.y{background:#ffbd2e;}
.td.g{background:#28c940;}
.term-title{font-family:var(--mono);font-size:10px;color:var(--muted2);letter-spacing:.02em;margin-left:8px;}
.tbadge{font-family:var(--mono);font-size:8px;color:var(--amber);letter-spacing:.06em;text-transform:uppercase;background:rgba(251,191,36,.1);padding:3px 8px;border-radius:4px;}
.term-output{flex:1;overflow-y:auto;padding:12px 14px;font-family:var(--mono);font-size:11px;line-height:1.6;color:var(--muted2);}
.term-input-row{display:flex;align-items:center;padding:8px 14px;font-family:var(--mono);font-size:11px;border-top:1px solid var(--bdr);}
.tp{color:var(--cyan);}
.term-input{flex:1;background:transparent;border:none;color:var(--text);font-family:var(--mono);font-size:11px;outline:none;caret-color:var(--cyan);}
.term-input::placeholder{color:var(--muted);}

#projects{background:rgba(5,7,12,.4);}
.wrap{max-width:1160px;margin:0 auto;padding:100px 52px;}
.sec-lbl{font-family:var(--mono);font-size:9px;color:var(--muted);letter-spacing:.16em;text-transform:uppercase;margin-bottom:12px;}
.sec-h{font-family:'Syne',sans-serif;font-size:clamp(40px,6vw,72px);font-weight:800;line-height:.95;letter-spacing:-.03em;margin-bottom:60px;}
.sec-h em{color:var(--cyan);font-style:normal;}

.project-arena{display:grid;grid-template-columns:1fr 560px;gap:80px;align-items:start;margin-bottom:80px;}
.proj-info-panel{min-height:520px;display:flex;flex-direction:column;justify-content:center;}
.pip-default{text-align:center;color:var(--muted);}
.pip-hint{font-family:var(--mono);font-size:11px;margin-bottom:16px;letter-spacing:.06em;}
.pip-arrows{display:flex;flex-direction:column;gap:12px;margin-top:24px;align-items:center;}
.pip-arrow{opacity:.5;animation:slide-right 1.8s ease-in-out infinite;}
@keyframes slide-right{0%,100%{transform:translateX(0);opacity:.3}50%{transform:translateX(8px);opacity:1}}

.pip-active{display:none;flex-direction:column;gap:16px;}
.pip-active.show{display:flex;}
.pip-a-num{font-family:'Syne',sans-serif;font-size:48px;font-weight:800;background:linear-gradient(135deg,var(--indigo),var(--cyan));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.pip-live-badge{display:inline-flex;width:fit-content;background:rgba(52,211,153,.15);color:var(--green);padding:6px 12px;border-radius:6px;font-family:var(--mono);font-size:9px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;}
.pip-a-icon{font-size:40px;line-height:1;}
.pip-a-name{font-family:'Syne',sans-serif;font-size:32px;font-weight:800;letter-spacing:-.02em;}
.pip-a-sub{font-family:var(--mono);font-size:10px;color:var(--cyan);letter-spacing:.08em;text-transform:uppercase;}
.pip-a-desc{font-size:14px;line-height:1.7;color:var(--muted2);max-width:480px;}
.pip-a-tags{display:flex;flex-wrap:wrap;gap:8px;margin-top:4px;}
.tag{display:inline-flex;align-items:center;gap:4px;padding:4px 10px;background:var(--surf);border:1px solid var(--bdr);border-radius:6px;font-family:var(--mono);font-size:8px;color:var(--muted2);text-transform:uppercase;letter-spacing:.04em;}
.pip-a-actions{display:flex;gap:10px;}

.watchface-wrap{position:relative;width:560px;height:540px;}
.watchface-bezel{position:absolute;width:100%;height:100%;perspective:1000px;}
.watchface{width:520px;height:520px;position:relative;margin:10px;transform-style:preserve-3d;transition:transform .12s ease-out;}
.wbubble{position:absolute;border-radius:50%;opacity:.42;filter:saturate(.45) brightness(.7);transition:all .28s ease;cursor:pointer;}
.wbubble.featured{opacity:.62;filter:saturate(.6) brightness(.8);animation:breathe 4s ease-in-out infinite;}
@keyframes breathe{0%,100%{transform:scale(1)}50%{transform:scale(1.04)}}
.wbubble-inner{width:100%;height:100%;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:36px;line-height:1;}
.watchface.is-hovering .wbubble{opacity:.1;filter:saturate(.15) brightness(.3) blur(.5px);}
.watchface.is-hovering .wbubble.active{opacity:1;filter:saturate(1.05) brightness(1.12);box-shadow:0 0 40px rgba(255,255,255,.12),0 0 80px rgba(255,255,255,.06);}
.watchface.is-hovering .wbubble.active .wbubble-inner{transform:scale(1.11) translateZ(12px);}

.list-toggle{text-align:center;margin:40px 0;}
.lt-btn{display:inline-flex;align-items:center;gap:8px;padding:10px 20px;border:1px solid var(--bdr);border-radius:8px;background:transparent;color:var(--text);font-family:var(--mono);font-size:10px;font-weight:500;letter-spacing:.08em;text-transform:uppercase;cursor:pointer;transition:all .2s;}
.lt-btn:hover{background:var(--surf);box-shadow:0 4px 16px rgba(255,255,255,.1);}
.lt-btn svg{width:14px;height:14px;opacity:.6;}

#list-view{display:grid;grid-template-columns:repeat(auto-fit,minmax(340px,1fr));gap:24px;}
.proj-card{border:1px solid var(--bdr);border-radius:12px;padding:24px;background:var(--surf);transition:all .3s;}
.proj-card:hover{background:var(--surf2);border-color:var(--bdr2);transform:translateY(-4px);}
.pc-icon{font-size:32px;margin-bottom:12px;}
.pc-num{font-family:'Syne',sans-serif;font-size:28px;font-weight:800;background:linear-gradient(135deg,var(--indigo),var(--cyan));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:8px;}
.pc-name{font-family:'Syne',sans-serif;font-size:20px;font-weight:800;margin-bottom:4px;}
.pc-sub{font-family:var(--mono);font-size:9px;color:var(--cyan);letter-spacing:.08em;text-transform:uppercase;margin-bottom:12px;}
.pc-desc{font-size:13px;line-height:1.6;color:var(--muted2);margin-bottom:16px;}
.pc-tags{display:flex;flex-wrap:wrap;gap:6px;}
.pc-tag{display:inline-flex;padding:3px 8px;background:var(--surf2);border:1px solid var(--bdr);border-radius:4px;font-family:var(--mono);font-size:7px;color:var(--muted2);text-transform:uppercase;letter-spacing:.03em;}

#about{background:rgba(5,7,12,.2);}
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:start;}
.abio{font-size:15px;line-height:1.8;color:var(--muted2);}
.abio p{margin-bottom:14px;}
.abio strong{color:var(--text);font-weight:500;}

.tl-wrap{display:flex;flex-direction:column;gap:32px;}
.tli{display:grid;grid-template-columns:16px 1fr;gap:20px;position:relative;}
.tli::before{content:'';position:absolute;left:7px;top:28px;width:2px;height:calc(100% + 32px);background:linear-gradient(to bottom,var(--indigo),transparent);opacity:.3;}
.tli:last-child::before{display:none;}
.tldot{width:16px;height:16px;border-radius:50%;background:var(--indigo);border:3px solid var(--bg);position:relative;z-index:2;}
.tldot.now{background:var(--cyan);box-shadow:0 0 12px rgba(34,211,238,.5);}
.tdate{font-family:var(--mono);font-size:9px;color:var(--cyan);letter-spacing:.1em;text-transform:uppercase;margin-bottom:2px;}
.trole{font-size:14px;font-weight:600;color:var(--text);margin-bottom:2px;}
.torg{font-family:var(--mono);font-size:10px;color:var(--muted);letter-spacing:.04em;margin-bottom:6px;}
.tdesc{font-size:13px;line-height:1.6;color:var(--muted2);}

#skills{background:rgba(5,7,12,.4);}
.skills-intro{font-size:15px;color:var(--muted2);margin-bottom:40px;max-width:700px;}
.skills-categories{display:flex;flex-direction:column;gap:48px;}
.skill-cat{display:flex;flex-direction:column;gap:20px;}
.skill-cat-label{display:flex;align-items:center;gap:12px;font-family:var(--mono);font-size:10px;font-weight:600;color:var(--muted);letter-spacing:.08em;text-transform:uppercase;margin-bottom:8px;}
.skill-cat-label::after{content:'';flex:1;height:1px;background:linear-gradient(to right,var(--indigo),transparent);opacity:.5;}
.skill-grid{display:flex;flex-wrap:wrap;gap:16px;}
.skill-badge{display:flex;flex-direction:column;align-items:center;gap:8px;opacity:0;animation:fadeSlideUp .5s ease forwards;}
.skill-badge:nth-child(1){animation-delay:.05s}
.skill-badge:nth-child(2){animation-delay:.1s}
.skill-badge:nth-child(3){animation-delay:.15s}
.skill-badge:nth-child(4){animation-delay:.2s}
.skill-badge:nth-child(5){animation-delay:.25s}
.skill-badge:nth-child(6){animation-delay:.3s}
@keyframes fadeSlideUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
.skill-icon-wrap{width:68px;height:68px;border-radius:16px;border:1px solid rgba(255,255,255,.08);display:flex;align-items:center;justify-content:center;background:var(--surf);transition:all .25s cubic-bezier(.34,1.56,.64,1);}
.skill-badge:hover .skill-icon-wrap{transform:translateY(-3px);box-shadow:0 8px 24px rgba(255,255,255,.15);filter:brightness(1.1);}
.skill-icon-wrap img{width:44px;height:44px;object-fit:contain;}
.skill-fallback{width:44px;height:44px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:var(--mono);font-size:11px;font-weight:700;color:#fff;background:linear-gradient(135deg,var(--indigo),var(--cyan));}
.skill-name{font-family:var(--mono);font-size:9px;color:var(--muted2);letter-spacing:.08em;text-transform:uppercase;text-align:center;width:68px;}

#certs,#contact{background:rgba(5,7,12,.2);}
.cgrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:20px;}
.cc{border:1px solid var(--bdr);border-radius:12px;padding:20px;background:var(--surf);transition:all .3s;display:flex;flex-direction:column;gap:12px;}
.cc:hover{background:var(--surf2);border-color:var(--bdr2);}
.cico{font-size:32px;line-height:1;}
.cname{font-size:16px;font-weight:600;color:var(--text);}
.corg{font-size:12px;color:var(--muted2);}
.cbadge{display:inline-flex;width:fit-content;padding:4px 10px;border-radius:6px;font-family:var(--mono);font-size:8px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;margin-top:auto;}
.cb-done{background:rgba(52,211,153,.15);color:var(--green);}
.cb-wip{background:rgba(251,191,36,.15);color:var(--amber);}

#contact{display:flex;align-items:center;justify-content:center;min-height:400px;}
.cta{text-align:center;max-width:600px;}
.cta-pre{font-family:var(--mono);font-size:9px;color:var(--muted);letter-spacing:.16em;text-transform:uppercase;margin-bottom:12px;}
.cta-h{font-family:'Syne',sans-serif;font-size:clamp(40px,6vw,72px);font-weight:800;line-height:.95;letter-spacing:-.03em;margin-bottom:16px;}
.cta-h em{color:var(--cyan);font-style:normal;}
.cta-sub{font-size:15px;color:var(--muted2);margin-bottom:32px;}
.cta-acts{display:flex;justify-content:center;gap:12px;flex-wrap:wrap;}

footer{border-top:1px solid var(--bdr);padding:40px 52px;text-align:center;max-width:1160px;margin:0 auto;}
.fm{font-family:var(--mono);font-size:9px;color:var(--muted);letter-spacing:.04em;}
.flinks{list-style:none;display:flex;justify-content:center;gap:24px;margin-bottom:20px;}
.flinks a{font-family:var(--mono);font-size:9px;color:var(--muted);text-decoration:none;transition:color .2s;text-transform:uppercase;letter-spacing:.04em;}
.flinks a:hover{color:var(--text);}

.divider{border:none;height:1px;background:linear-gradient(to right,transparent,var(--bdr),transparent);margin:0;}

.d1{animation-delay:.07s!important}
.d2{animation-delay:.14s!important}
.d3{animation-delay:.21s!important}
.d4{animation-delay:.28s!important}

.fade-in{opacity:0;transform:translateY(16px);}
.fade-in.visible{opacity:1;transform:translateY(0);transition:all .6s ease;}

@media(max-width:1024px){
  #home{grid-template-columns:1fr;padding:80px 40px;}
  .hero-right{display:none;}
  .project-arena{grid-template-columns:1fr;gap:40px;}
  .watchface-wrap{width:100%;max-width:520px;}
  .about-grid{grid-template-columns:1fr;gap:40px;}
  .skill-grid{justify-content:center;}
  nav{padding:0 40px;}
  .wrap{padding:80px 40px;}
}
</style>
</head>
<body>

<div class="ab"><div class="bl b1"></div><div class="bl b2"></div><div class="bl b3"></div></div>
<div class="go"></div>

<div class="scroll-line-wrap">
  <div class="slt">
    <div class="slf" id="slf"></div>
    <div class="sl-dots">
      <div class="sld act" data-s="home" data-l="Home"></div>
      <div class="sld" data-s="projects" data-l="Projects"></div>
      <div class="sld" data-s="about" data-l="About"></div>
      <div class="sld" data-s="skills" data-l="Skills"></div>
      <div class="sld" data-s="contact" data-l="Contact"></div>
    </div>
  </div>
</div>

<nav>
  <a href="#home" class="logo">RS<span>.dev</span></a>
  <ul class="navul">
    <li><a href="#home">Home</a></li>
    <li><a href="#projects">Projects</a></li>
    <li><a href="#about">About</a></li>
    <li><a href="#skills">Skills</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
  <a href="./Ryan_Sokolowsky_Resume.pdf" download class="nav-dl">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>Resume
  </a>
</nav>

<section id="home" class="section">
  <div class="hero-left fade-in">
    <div class="eyebrow">Available for opportunities</div>
    <h1 class="name"><span class="w1">Ryan</span><span class="w2">Sokolowsky</span></h1>
