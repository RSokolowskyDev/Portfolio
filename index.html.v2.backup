<script>
const PROJECTS = [
  {id:'mark-miller',num:'01',icon:'🏎️',featured:true,live:true,name:'Mark Miller Subaru',sub:'AI Lead Intelligence System',grad:'linear-gradient(135deg,#4f46e5,#0ea5e9)',sz:116,depth:4,desc:'Full-stack, two-agent AI system for real dealership operations. CrewAI pipeline scores leads, writes personalized emails, and triggers post-sale sequences.',tags:[['CrewAI','ti'],['FastAPI','tc'],['React','tg'],['Gemini 2.5','ta']]},
  {id:'sentinel',num:'02',icon:'⚡',name:'Sentinel',sub:'AI Token Optimization Engine',grad:'linear-gradient(135deg,#06b6d4,#10b981)',sz:90,depth:2,desc:'Python orchestration system routing LLM queries to cut API costs without sacrificing accuracy. Dual-model validation catches hallucinations.',tags:[['Python','tc'],['LLM APIs','ti'],['Orchestration','tg']]},
  {id:'drone',num:'03',icon:'🚁',name:'Autonomous Drone System',sub:'Ground-Up Hardware Build',grad:'linear-gradient(135deg,#f59e0b,#ef4444)',sz:90,depth:1,desc:'Fully autonomous drone built from component selection to firmware-level integration. Custom Lua flight logic and C++ patches.',tags:[['ArduPilot','ta'],['C++','tc'],['Lua','tg']]},
  {id:'paint-matcher',num:'04',icon:'🎨',name:'AI Paint Color Matcher',sub:'Sensor → ML Inference',grad:'linear-gradient(135deg,#ec4899,#a855f7)',sz:90,depth:2,desc:'Engineering capstone: hardware color sensor feeds trained Create ML model to predict paint pigment mixing ratios in real time.',tags:[['Create ML','tc'],['Python','tg'],['Sensor','tp2']]},
  {id:'semantic-layer',num:'05',icon:'🧠',name:'Semantic Universe Layer',sub:'Transparent AI Reasoning',grad:'linear-gradient(135deg,#6366f1,#a855f7)',sz:90,depth:1,desc:'Glass-box semantic abstraction layer making AI reasoning fully interpretable and efficient on commodity hardware.',tags:[['AI Arch','ti'],['Python','tc']]},
  {id:'resumegen',num:'06',icon:'📄',name:'ResumeGen',sub:'Automated Resume Generation',grad:'linear-gradient(135deg,#10b981,#06b6d4)',sz:90,depth:2,desc:'Python tool that dynamically generates tailored resumes from JSON config, enabling modular swapping per application target.',tags:[['Python','tc'],['JSON','tg'],['PDF','tp2']]},
  {id:'video-pipeline',num:'07',icon:'🎬',name:'Automated Video Pipeline',sub:'Batch Processing at Scale',grad:'linear-gradient(135deg,#8b5cf6,#ec4899)',sz:90,depth:1,desc:'Python/MoviePy batch pipeline automating video editing — cuts, captions, exports, encoding at scale.',tags:[['Python','tc'],['MoviePy','tg'],['FFmpeg','ta']]}
];

const BUBBLE_POS = [
  {id:'mark-miller',cx:260,cy:260},
  {id:'sentinel',cx:260,cy:82},
  {id:'drone',cx:414,cy:171},
  {id:'paint-matcher',cx:414,cy:349},
  {id:'semantic-layer',cx:260,cy:438},
  {id:'resumegen',cx:106,cy:349},
  {id:'video-pipeline',cx:106,cy:171}
];

const SKILLS_DATA = [
  {cat:'Languages',items:[{name:'Python',icon:'🐍'},{name:'JavaScript',icon:'⚡'},{name:'SQL',icon:'🗄️'},{name:'Java',icon:'☕'},{name:'C++',icon:'🔧'},{name:'Lua',icon:'🎮'}]},
  {cat:'AI & Machine Learning',items:[{name:'CrewAI',icon:'🦾'},{name:'LLM APIs',icon:'🧠'},{name:'FastAPI',icon:'⚙️'},{name:'Create ML',icon:'🤖'},{name:'Prompt Eng.',icon:'💬'},{name:'Inference',icon:'⚡'}]},
  {cat:'Cloud & Backend',items:[{name:'AWS',icon:'☁️'},{name:'Firebase',icon:'🔥'},{name:'React',icon:'⚛️'},{name:'Node.js',icon:'🟢'},{name:'Git',icon:'📦'},{name:'Salesforce',icon:'☁️'}]},
  {cat:'Tools & Hardware',items:[{name:'ArduPilot',icon:'🚁'},{name:'Tableau',icon:'📊'},{name:'Android',icon:'📱'},{name:'MoviePy',icon:'🎬'},{name:'Excel',icon:'📋'},{name:'Spanish',icon:'🌎'}]}
];

let currentProject = null;
let listViewOpen = false;

function initWatchface(){
  const wf = document.getElementById('watchface');
  BUBBLE_POS.forEach(pos => {
    const proj = PROJECTS.find(p => p.id === pos.id);
    const size = proj.sz;
    const left = pos.cx - size/2;
    const top = pos.cy - size/2;
    const isFeatured = proj.featured;
    const bubble = document.createElement('div');
    bubble.className = `wbubble ${isFeatured?'featured':''}`;
    bubble.style.cssText = `
      width:${size}px;height:${size}px;
      left:${left}px;top:${top}px;
      background:${proj.grad};
      z-index:${proj.depth};
    `;
    bubble.innerHTML = `<div class="wbubble-inner">${proj.icon}</div>`;
    bubble.addEventListener('mouseenter', () => selectProject(proj.id));
    wf.appendChild(bubble);
  });
}

function selectProject(id){
  currentProject = id;
  const proj = PROJECTS.find(p => p.id === id);
  const bubbles = document.querySelectorAll('.wbubble');
  const wf = document.getElementById('watchface');
  bubbles.forEach(b => b.classList.remove('active'));
  bubbles.forEach((b, i) => {
    if(BUBBLE_POS[i].id === id) b.classList.add('active');
  });
  wf.classList.add('is-hovering');

  const pipDefault = document.getElementById('pip-default');
  const pipActive = document.getElementById('pip-active');
  pipDefault.style.display = 'none';
  pipActive.classList.add('show');

  document.getElementById('pip-num').textContent = proj.num;
  document.getElementById('pip-icon').textContent = proj.icon;
  document.getElementById('pip-name').textContent = proj.name;
  document.getElementById('pip-sub').textContent = proj.sub;
  document.getElementById('pip-desc').textContent = proj.desc;
  document.getElementById('pip-live').style.display = proj.live ? 'inline-flex' : 'none';

  const tags = document.getElementById('pip-tags');
  tags.innerHTML = proj.tags.map(t => `<div class="tag">${t[0]}</div>`).join('');
}

function hideProject(){
  const wf = document.getElementById('watchface');
  const bubbles = document.querySelectorAll('.wbubble');
  wf.classList.remove('is-hovering');
  bubbles.forEach(b => b.classList.remove('active'));

  const pipDefault = document.getElementById('pip-default');
  const pipActive = document.getElementById('pip-active');
  pipDefault.style.display = 'block';
  pipActive.classList.remove('show');
  currentProject = null;
}

function initWatchfaceInteraction(){
  const bezel = document.getElementById('wf-bezel');
  const wf = document.getElementById('watchface');
  bezel.addEventListener('mousemove', (e) => {
    if(!currentProject) return;
    const rect = bezel.getBoundingClientRect();
    const x = e.clientX - rect.left - rect.width/2;
    const y = e.clientY - rect.top - rect.height/2;
    const rotX = -y * 0.014;
    const rotY = x * 0.014;
    wf.style.transform = `rotateX(${rotX}deg) rotateY(${rotY}deg)`;
  });
  bezel.addEventListener('mouseleave', () => {
    wf.style.transform = 'rotateX(0) rotateY(0)';
    hideProject();
  });
}

function initListView(){
  const btn = document.getElementById('lt-list');
  const list = document.getElementById('list-view');
  btn.addEventListener('click', () => {
    listViewOpen = !listViewOpen;
    if(listViewOpen){
      list.innerHTML = PROJECTS.map(p => `
        <div class="proj-card fade-in">
          <div class="pc-icon">${p.icon}</div>
          <div class="pc-num">${p.num}</div>
          <div class="pc-name">${p.name}</div>
          <div class="pc-sub">${p.sub}</div>
          <div class="pc-desc">${p.desc}</div>
          <div class="pc-tags">${p.tags.map(t => `<div class="pc-tag">${t[0]}</div>`).join('')}</div>
        </div>
      `).join('');
      btn.textContent = '▼ Hide list';
    } else {
      list.innerHTML = '';
      btn.textContent = '▶ View detailed list';
    }
  });
}

function initSkills(){
  const container = document.getElementById('skills-container');
  container.innerHTML = SKILLS_DATA.map(cat => `
    <div class="skill-cat">
      <div class="skill-cat-label">${cat.cat}</div>
      <div class="skill-grid">
        ${cat.items.map(item => `
          <div class="skill-badge">
            <div class="skill-icon-wrap">
              <img src="images/${item.name.toLowerCase().replace(/[^a-z0-9]/g,'')}.png" alt="${item.name}" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
              <div class="skill-fallback">${item.name.substring(0,2).toUpperCase()}</div>
            </div>
            <span class="skill-name">${item.name}</span>
          </div>
        `).join('')}
      </div>
    </div>
  `).join('');
}

function initTerminal(){
  const inp = document.getElementById('hero-inp');
  const out = document.getElementById('hero-out');
  inp.addEventListener('keypress', (e) => {
    if(e.key !== 'Enter') return;
    const cmd = inp.value.trim();
    inp.value = '';
    out.innerHTML += `<div style="color:var(--cyan);">$ ${cmd}</div>`;
    const resp = executeCommand(cmd);
    out.innerHTML += `<div>${resp}</div>`;
    out.scrollTop = out.scrollHeight;
  });
  out.innerHTML = '<div style="color:var(--muted);">Welcome. Try "help" to see available commands.</div>';
}

function executeCommand(cmd){
  const lower = cmd.toLowerCase().trim();
  if(lower === 'help') return 'Available commands: whoami, skills, projects, experience, contact, status, hire, clear';
  if(lower === 'whoami') return 'Ryan Sokolowsky - AI Solutions & Automation Engineer, building intelligent systems from model layer to hardware.';
  if(lower === 'skills') return 'Python • JavaScript • AWS • React • CrewAI • FastAPI • ArduPilot • Machine Learning';
  if(lower === 'projects') return '7 projects: Mark Miller Subaru AI, Sentinel, Autonomous Drone, Paint Matcher, Semantic Layer, ResumeGen, Video Pipeline';
  if(lower === 'experience') return '2025-now: UCCU • 2023-25: Missionary Lead • 2022-23: Fitness Manager • 2020-21: Code Ninjas Lead Instructor';
  if(lower === 'contact') return 'Email: ryan.sokolowsky@gmail.com | Phone: (331) 298-3934 | GitHub: github.com/RSokolowskyDev';
  if(lower === 'status') return '✓ Available for hire • Open to AI engineering & automation consulting';
  if(lower === 'hire') window.location.href = 'mailto:ryan.sokolowsky@gmail.com';
  if(lower === 'clear'){ document.getElementById('hero-out').innerHTML = ''; return ''; }
  return 'Command not found. Type "help" for available commands.';
}

function initScrollProgress(){
  window.addEventListener('scroll', () => {
    const progress = window.scrollY / (document.documentElement.scrollHeight - window.innerHeight);
    document.getElementById('slf').style.height = (progress * 100) + '%';

    const sections = ['home','projects','about','skills','contact'];
    let active = 'home';
    sections.forEach(id => {
      const el = document.getElementById(id);
      if(el && window.scrollY >= el.offsetTop - 100) active = id;
    });
    document.querySelectorAll('.sld').forEach(d => {
      d.classList.toggle('act', d.dataset.s === active);
    });
  }, {passive:true});
}

function initScrollDots(){
  document.querySelectorAll('.sld').forEach(dot => {
    dot.addEventListener('click', () => {
      const id = dot.dataset.s;
      const el = document.getElementById(id);
      if(el) el.scrollIntoView({behavior:'smooth'});
    });
  });
}

function initScrollAnimations(){
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if(e.isIntersecting) e.target.classList.add('visible');
    });
  }, {threshold:.08});
  document.querySelectorAll('.fade-in').forEach(el => obs.observe(el));
}

document.addEventListener('DOMContentLoaded', () => {
  initWatchface();
  initWatchfaceInteraction();
  initListView();
  initSkills();
  initTerminal();
  initScrollProgress();
  initScrollDots();
  initScrollAnimations();
});
</script>
</body>
</html>
